def load_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise BootstrapError(f"invalid JSON in {path}: {exc}") from exc


def merge_config(base: dict[str, Any], override: dict[str, Any]) -> dict[str, Any]:
    merged = dict(base)
    for key, value in override.items():
        if isinstance(value, dict) and isinstance(merged.get(key), dict):
            merged[key] = merge_config(merged[key], value)
        else:
            merged[key] = value
    return merged


def run_command(
    args: list[str],
    *,
    cwd: Path | None = None,
    timeout: int = 120,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    try:
        proc = subprocess.run(
            args,
            cwd=str(cwd) if cwd else None,
            text=True,
            capture_output=True,
            timeout=timeout,
            check=False,
        )
    except FileNotFoundError as exc:
        raise BootstrapError(f"required command not found: {args[0]}") from exc
    except subprocess.TimeoutExpired as exc:
        joined = " ".join(args)
        raise BootstrapError(f"command timed out after {timeout}s: {joined}") from exc

    if check and proc.returncode != 0:
        joined = " ".join(args)
        detail = (proc.stderr or proc.stdout).strip()
        raise BootstrapError(f"command failed: {joined}\n{detail}")
    return proc


def command_exists(name: str) -> bool:
    return shutil.which(name) is not None


def resolve_projects_base(cli_value: str | None, config_data: dict[str, Any]) -> Path:
    if cli_value:
        return Path(cli_value).expanduser().resolve()

    config_value = str(config_data.get("projects_base", "")).strip()
    if config_value:
        return Path(config_value).expanduser().resolve()

    env_value = os.environ.get("NTM_PROJECTS_BASE", "").strip()
    if env_value:
        return Path(env_value).expanduser().resolve()

    if command_exists("ntm"):
        proc = run_command(["ntm", "config", "get", "projects_base"], timeout=20, check=False)
        value = (proc.stdout or "").strip()
        if proc.returncode == 0 and value:
            return Path(value).expanduser().resolve()

    if platform.system().lower() == "darwin":
        return (Path.home() / "Developer").resolve()
    return (Path.home() / "ntm_Dev").resolve()


def normalize_remote(value: str) -> str:
    value = value.strip()
    if not value:
        return value

    if value.startswith("git@"):
        host_path = value.split("@", 1)[1]
        host, path = host_path.split(":", 1)
        return f"{host}/{path.removesuffix('.git')}"

    if value.startswith("https://") or value.startswith("http://") or value.startswith("ssh://"):
        value = value.split("://", 1)[1]
        if "@" in value:
            value = value.split("@", 1)[1]
        return value.removesuffix(".git").rstrip("/")

    path = Path(value).expanduser()
    if path.exists():
        return str(path.resolve())

    return value.removesuffix(".git").rstrip("/")


def ensure_parent(path: Path, dry_run: bool) -> None:
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)


def write_file_if_missing(path: Path, content: str, dry_run: bool) -> bool:
    if path.exists():
        return False
    ensure_parent(path, dry_run)
    if not dry_run:
        path.write_text(content)
    return True


def split_lines(text: str) -> list[str]:
    if not text:
        return []
    stripped = text.rstrip("\n")
    if not stripped:
        return []
    return [line.rstrip("\r") for line in stripped.splitlines()]


def ensure_gitignore_entry(path: Path, entry: str, dry_run: bool) -> None:
    if not path.exists():
        return
    lines = split_lines(path.read_text())
    target = entry.rstrip("/")
    if any(line.rstrip("/") == target for line in lines):
        return
    lines.append(entry)
    if not dry_run:
        path.write_text("\n".join(lines) + "\n")


def is_git_repo(path: Path) -> bool:
    return (path / ".git").exists()


def git_ref_exists(project_dir: Path, ref_name: str) -> bool:
    proc = run_command(
        ["git", "show-ref", "--verify", "--quiet", ref_name],
        cwd=project_dir,
        timeout=20,
        check=False,
    )
    return proc.returncode == 0


def git_dirty(project_dir: Path) -> bool:
    proc = run_command(
        ["git", "status", "--porcelain"],
        cwd=project_dir,
        timeout=20,
        check=True,
    )
    return bool(proc.stdout.strip())


def current_branch(project_dir: Path) -> str:
    proc = run_command(
        ["git", "branch", "--show-current"],
        cwd=project_dir,
        timeout=20,
        check=True,
    )
    return proc.stdout.strip()


def tmux_session_exists(name: str) -> bool:
    proc = run_command(["tmux", "has-session", "-t", name], timeout=10, check=False)
    return proc.returncode == 0


def detect_prompt_pane(session: str) -> int:
    proc = run_command(
        ["tmux", "list-panes", "-t", session, "-F", "#{pane_index}\t#{pane_title}"],
        timeout=20,
        check=True,
    )
    panes: list[tuple[int, str]] = []
    for raw_line in proc.stdout.splitlines():
        if not raw_line.strip():
            continue
        parts = raw_line.split("\t", 1)
        if len(parts) != 2:
            continue
        try:
            pane_index = int(parts[0])
        except ValueError:
            continue
        panes.append((pane_index, parts[1]))

    if not panes:
        raise BootstrapError(f"no panes found in tmux session {session!r}")

    agent_panes = [pane_index for pane_index, title in panes if "__" in title]
    if agent_panes:
        return min(agent_panes)
    return min(pane_index for pane_index, _ in panes)


def detect_language(project_dir: Path) -> tuple[str, str]:
    if (project_dir / "go.mod").exists():
        return "Go", GO_RULES
    if (project_dir / "pyproject.toml").exists() or (project_dir / "requirements.txt").exists():
        return "Python", PYTHON_RULES
    if (project_dir / "package.json").exists():
        return "Node", NODE_RULES
    if (project_dir / "Cargo.toml").exists():
        return "Rust", RUST_RULES
    return "Generic", GENERIC_RULES


def render_agents(project_dir: Path) -> str:
    language, rules = detect_language(project_dir)
    return AGENTS_TEMPLATE.substitute(
        project_name=project_dir.name,
        language=language,
        generated_at=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        language_rules=rules,
    ).rstrip() + "\n"


def acquire_repo(project_dir: Path, repo_url: str, dry_run: bool) -> bool:
    repo_url = repo_url.strip()
    if not repo_url:
        raise BootstrapError("--repo is required")

    if not project_dir.exists():
        if dry_run:
            return True
        project_dir.parent.mkdir(parents=True, exist_ok=True)
        run_command(
            ["git", "clone", "--branch", "main", "--single-branch", repo_url, str(project_dir)],
            cwd=project_dir.parent,
            timeout=180,
        )
        return True

    if not is_git_repo(project_dir):
        raise BootstrapError(f"project directory exists and is not a git repository: {project_dir}")

    ensure_origin(project_dir, repo_url, dry_run)
    return False


def ensure_origin(project_dir: Path, repo_url: str, dry_run: bool) -> None:
    proc = run_command(
        ["git", "remote", "get-url", "origin"],
        cwd=project_dir,
        timeout=20,
        check=False,
    )
    if proc.returncode != 0:
        if not dry_run:
            run_command(["git", "remote", "add", "origin", repo_url], cwd=project_dir, timeout=20)
        return

    current = proc.stdout.strip()
    if normalize_remote(current) != normalize_remote(repo_url):
        raise BootstrapError(f"origin remote mismatch: have {current!r}, expected {repo_url!r}")


def ensure_main_branch(project_dir: Path, dry_run: bool) -> list[str]:
    warnings: list[str] = []
    dirty = git_dirty(project_dir)
    branch = current_branch(project_dir)

    if branch and branch != "main" and dirty:
        raise BootstrapError(
            f"repository is on branch {branch!r} with uncommitted changes; "
            "switch to main or clean the worktree before bootstrapping"
        )

    if branch != "main":
        if not dry_run:
            run_command(["git", "fetch", "origin", "main"], cwd=project_dir, timeout=60)
            if git_ref_exists(project_dir, "refs/heads/main"):
                run_command(["git", "checkout", "main"], cwd=project_dir, timeout=30)
            else:
                run_command(
                    ["git", "checkout", "-b", "main", "--track", "origin/main"],
                    cwd=project_dir,
                    timeout=30,
                )
        dirty = False

    if dirty:
        warnings.append("working tree already has local changes; skipped git pull on main")
        return warnings

    if not dry_run:
        run_command(["git", "pull", "--ff-only", "origin", "main"], cwd=project_dir, timeout=60)
    return warnings


def ensure_gitignore(project_dir: Path, dry_run: bool) -> bool:
    path = project_dir / ".gitignore"
    created = write_file_if_missing(path, GITIGNORE_CONTENT, dry_run)
    ensure_gitignore_entry(path, ".ntm/", dry_run)
    return created


def ensure_vscode(project_dir: Path, skip: bool, dry_run: bool) -> bool:
    if skip:
        return False
    return write_file_if_missing(project_dir / ".vscode" / "settings.json", VSCODE_SETTINGS, dry_run)


def ensure_claude(project_dir: Path, skip: bool, dry_run: bool) -> bool:
    if skip:
        return False

    settings_path = project_dir / ".claude" / "settings.toml"
    review_path = project_dir / ".claude" / "commands" / "review.md"
    created = False
    if write_file_if_missing(settings_path, CLAUDE_SETTINGS, dry_run):
        created = True
    if write_file_if_missing(review_path, CLAUDE_REVIEW_COMMAND, dry_run):
        created = True
    return created


def ensure_ntm_scaffold(project_dir: Path, dry_run: bool) -> tuple[bool, bool]:
    dirs = [
        project_dir / ".ntm",
        project_dir / ".ntm" / "logs",
        project_dir / ".ntm" / "pids",
        project_dir / ".ntm" / "cache",
        project_dir / ".ntm" / "bin",
    ]
    if not dry_run:
        for path in dirs:
            path.mkdir(parents=True, exist_ok=True)

    created_any = False
    if write_file_if_missing(project_dir / ".ntm" / "config.yaml", NTM_CONFIG, dry_run):
        created_any = True
    if write_file_if_missing(project_dir / ".ntm" / "policy.yaml", NTM_POLICY, dry_run):
        created_any = True

    agents_created = write_file_if_missing(project_dir / "AGENTS.md", render_agents(project_dir), dry_run)
    if agents_created:
        created_any = True

    ensure_gitignore_entry(project_dir / ".gitignore", ".ntm/", dry_run)
    return created_any, agents_created


def init_beads(project_dir: Path, dry_run: bool) -> tuple[bool, str]:
    beads_dir = project_dir / ".beads"
    if beads_dir.exists():
        return False, ""
    if not command_exists("br"):
        raise BootstrapError("br is required to initialize beads tracking")
    if dry_run:
        return True, ""
    run_command(["br", "init", "--json"], cwd=project_dir, timeout=60)
    return True, ""


def ensure_sync_branch(project_dir: Path, branch: str, dry_run: bool) -> None:
    branch = branch.strip()
    if not branch:
        return

    if not git_ref_exists(project_dir, f"refs/heads/{branch}"):
        if git_ref_exists(project_dir, f"refs/remotes/origin/{branch}"):
            if not dry_run:
                run_command(
                    ["git", "branch", "--track", branch, f"origin/{branch}"],
                    cwd=project_dir,
                    timeout=30,
                )
        else:
            if not dry_run:
                run_command(["git", "branch", branch, "main"], cwd=project_dir, timeout=30)

    if not git_ref_exists(project_dir, f"refs/remotes/origin/{branch}"):
        if not dry_run:
            run_command(["git", "push", "-u", "origin", branch], cwd=project_dir, timeout=90)
        return

    if not dry_run:
        run_command(
            ["git", "branch", "--set-upstream-to", f"origin/{branch}", branch],
            cwd=project_dir,
            timeout=30,
        )


def configure_beads_sync(project_dir: Path, branch: str, dry_run: bool) -> None:
    if not branch.strip():
        return
    if not command_exists("br"):
        raise BootstrapError("br is required to configure beads sync.branch")
    if not dry_run:
        run_command(["br", "config", "set", f"sync.branch={branch}"], cwd=project_dir, timeout=30)


def resolve_plan_file(project_dir: Path, plan_path: str) -> tuple[Path, str]:
    plan_path = plan_path.strip() or "Plan.md"
    display = Path(plan_path)
    abs_path = display if display.is_absolute() else project_dir / display
    abs_path = abs_path.resolve()
    if not abs_path.exists():
        raise BootstrapError(f"plan file not found: {display}")
    if abs_path.is_dir():
        raise BootstrapError(f"plan path is a directory: {display}")

    try:
        display_name = str(abs_path.relative_to(project_dir))
    except ValueError:
        display_name = str(display)

    return abs_path, display_name


def build_spawn_command(session: str, cc: int, cod: int, gmi: int, no_user: bool) -> list[str]:
    if cc == 0 and cod == 0 and gmi == 0:
        cod = 1

    cmd = ["ntm", "spawn", session, "--safety", "--no-cass-context", "--no-recovery"]
    if no_user:
        cmd.append("--no-user")
    if cc > 0:
        cmd.append(f"--cc={cc}")
    if cod > 0:
        cmd.append(f"--cod={cod}")
    if gmi > 0:
        cmd.append(f"--gmi={gmi}")
    return cmd


def send_prompt(
    session: str,
    pane: int,
    template_name: str,
    plan_abs_path: Path,
    plan_display_name: str,
    project_dir: Path,
    dry_run: bool,
) -> None:
    cmd = [
        "ntm",
        "send",
        session,
        f"--pane={pane}",
        "--no-cass-check",
        "-t",
        template_name,
        "--var",
        f"plan_file={plan_display_name}",
        "--file",
        str(plan_abs_path),
        "-c",
        str(project_dir / "AGENTS.md"),
    ]
    if not dry_run:
        run_command(cmd, cwd=project_dir, timeout=180)


def interactive_terminal_available() -> bool:
    return sys.stdin.isatty() and sys.stdout.isatty()


def inside_tmux() -> bool:
    return bool(os.environ.get("TMUX", "").strip())


def should_auto_attach(args: argparse.Namespace) -> bool:
    return (
        not args.no_spawn
        and not args.dry_run
        and not args.json
        and interactive_terminal_available()
    )


def attach_session(session: str, project_dir: Path) -> None:
    cmd = ["ntm", "attach", session]
    try:
        proc = subprocess.run(cmd, cwd=str(project_dir), check=False)
    except FileNotFoundError as exc:
        raise BootstrapError(f"required command not found: {cmd[0]}") from exc

    if proc.returncode != 0:
        raise BootstrapError(f"command failed: {' '.join(cmd)}")


def start_delayed_prompt_send(
    session: str,
    pane: int,
    template_name: str,
    plan_abs_path: Path,
    plan_display_name: str,
    project_dir: Path,
    errors: list[str],
    delay_seconds: float = 0.5,
) -> threading.Thread:
    def worker() -> None:
        try:
            time.sleep(delay_seconds)
            send_prompt(
                session,
                pane,
                template_name,
                plan_abs_path,
                plan_display_name,
                project_dir,
                False,
            )
        except BootstrapError as exc:
            errors.append(str(exc))

    thread = threading.Thread(
        target=worker,
        name=f"ntm-bootstrap-send-{session}",
        daemon=True,
    )
    thread.start()
    return thread


def handle_post_spawn_interaction(
    *,
    session: str,
    project_dir: Path,
    auto_attach: bool,
    pane: int | None,
    template_name: str,
    plan_abs_path: Path | None,
    plan_display_name: str,
) -> bool:
    if plan_abs_path is None:
        if auto_attach:
            attach_session(session, project_dir)
            return True
        return False

    if pane is None:
        raise BootstrapError("prompt pane must be resolved before sending the planning prompt")

    if not auto_attach:
        send_prompt(
            session,
            pane,
            template_name,
            plan_abs_path,
            plan_display_name,
            project_dir,
            False,
        )
        return False

    if inside_tmux():
        attach_session(session, project_dir)
        send_prompt(
            session,
            pane,
            template_name,
            plan_abs_path,
            plan_display_name,
            project_dir,
            False,
        )
        return True

    errors: list[str] = []
    thread = start_delayed_prompt_send(
        session,
        pane,
        template_name,
        plan_abs_path,
        plan_display_name,
        project_dir,
        errors,
    )
    attach_error: BootstrapError | None = None
    # Outside tmux, attaching takes over the terminal. Queue prompt delivery with a
    # short delay so the user lands in the session before the planning prompt arrives.
    try:
        attach_session(session, project_dir)
    except BootstrapError as exc:
        attach_error = exc
    thread.join()
    if attach_error is not None:
        raise attach_error
    if errors:
        raise BootstrapError(errors[0])
    return True


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="ntm-bootstrap",
        description="Standalone bootstrap wrapper for repo-first NTM project kickoff.",
    )
    parser.add_argument("project_name", help="session/project name under the projects base")
    parser.add_argument("--repo", required=True, help="git remote to clone or adopt")
    parser.add_argument("--projects-base", help="override NTM projects base")
    parser.add_argument("--plan", help="plan file path relative to the project root")
    parser.add_argument(
        "--template",
        help="ntm send template to dispatch after spawn",
    )
    parser.add_argument(
        "--sync-branch",
        help="beads sync branch to create and configure (empty string to skip)",
    )
    parser.add_argument("--pane", type=int, help="target pane for the planning prompt")
    parser.add_argument("--cc", type=int, default=None, help="number of Claude agents to spawn")
    parser.add_argument("--cod", type=int, default=None, help="number of Codex agents to spawn")
    parser.add_argument("--gmi", type=int, default=None, help="number of Gemini agents to spawn")
    parser.add_argument("--no-user", action="store_true", help="spawn without a reserved user pane")
    parser.add_argument("--no-vscode", action="store_true", help="skip VSCode settings scaffolding")
    parser.add_argument("--no-claude", action="store_true", help="skip Claude config scaffolding")
    parser.add_argument("--no-spawn", action="store_true", help="skip ntm spawn")
    parser.add_argument("--no-send", action="store_true", help="skip ntm send")
    parser.add_argument("--dry-run", action="store_true", help="show intent without making changes")
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    parser.add_argument("--config", help="config file path", default=str(DEFAULT_CONFIG_PATH))
    return parser.parse_args()


def print_summary(result: BootstrapResult) -> None:
    if result.cloned:
        print(f"Cloned {result.repo_url} into {result.working_directory}")
    else:
        print(f"Using existing repository at {result.working_directory}")
    print("Repository is on main")
    if result.gitignore_created:
        print("Created .gitignore")
    if result.vscode_created:
        print("Created VSCode settings")
    if result.claude_created:
        print("Created Claude Code config")
    if result.ntm_initialized:
        print("Initialized NTM project scaffolding")
    if result.agents_created:
        print("Created AGENTS.md")
    if result.beads_initialized:
        print("Initialized beads tracking")
    if result.sync_branch:
        print(f"Configured beads sync branch {result.sync_branch!r}")
    if result.session_spawned:
        print(f"Spawned session {result.session!r}")
    elif result.session_reused:
        print(f"Reused session {result.session!r}")
    if result.session_attached:
        print(f"Attached to session {result.session!r}")
    if result.plan_file:
        print(f"Sent template {result.prompt_template!r} to pane {result.prompt_pane} using {result.plan_file}")
    for warning in result.warnings:
        print(f"Warning: {warning}", file=sys.stderr)


def main() -> int:
    args = parse_args()
    config_path = Path(args.config).expanduser()
    config_data = merge_config(DEFAULT_CONFIG, load_json(config_path))

    projects_base = resolve_projects_base(args.projects_base, config_data)
    project_dir = (projects_base / args.project_name).resolve()

    plan_file = args.plan if args.plan is not None else str(config_data.get("plan_file", "Plan.md"))
    template_name = args.template if args.template is not None else str(config_data.get("template", "turn_plan_into_beads"))
    sync_branch = args.sync_branch if args.sync_branch is not None else str(config_data.get("sync_branch", "beads-sync"))

    spawn_cfg = config_data.get("spawn", {})
    cc_count = args.cc if args.cc is not None else int(spawn_cfg.get("cc", 0))
    cod_count = args.cod if args.cod is not None else int(spawn_cfg.get("cod", 1))
    gmi_count = args.gmi if args.gmi is not None else int(spawn_cfg.get("gmi", 0))
    no_user = bool(args.no_user or spawn_cfg.get("no_user", False))
    no_vscode = bool(args.no_vscode or config_data.get("skip_vscode", False))
    no_claude = bool(args.no_claude or config_data.get("skip_claude", False))
    auto_attach = should_auto_attach(args)

    result = BootstrapResult(
        working_directory=str(project_dir),
        repo_url=args.repo.strip(),
        session=args.project_name,
        prompt_template=template_name,
    )

    try:
        for required in ("git", "ntm", "tmux"):
            if required == "tmux" and args.no_spawn and args.no_send:
                continue
            if required == "ntm" and args.no_spawn and args.no_send:
                continue
            if not command_exists(required):
                raise BootstrapError(f"required command not found in PATH: {required}")

        result.cloned = acquire_repo(project_dir, args.repo, args.dry_run)
        if args.dry_run and result.cloned and not project_dir.exists():
            raise BootstrapError(
                "dry-run cannot continue when the target checkout does not exist yet; "
                "rerun without --dry-run or point at an existing repo"
            )
        result.warnings.extend(ensure_main_branch(project_dir, args.dry_run))
        result.main_ready = True

        result.gitignore_created = ensure_gitignore(project_dir, args.dry_run)
        result.vscode_created = ensure_vscode(project_dir, no_vscode, args.dry_run)
        result.claude_created = ensure_claude(project_dir, no_claude, args.dry_run)
        _, result.agents_created = ensure_ntm_scaffold(project_dir, args.dry_run)
        result.ntm_initialized = True
        result.beads_initialized, result.beads_warning = init_beads(project_dir, args.dry_run)

        if sync_branch.strip():
            ensure_sync_branch(project_dir, sync_branch, args.dry_run)
            configure_beads_sync(project_dir, sync_branch, args.dry_run)
            result.sync_branch = sync_branch

        if not args.no_send:
            plan_abs_path, plan_display_name = resolve_plan_file(project_dir, plan_file)
            result.plan_file = plan_display_name
        else:
            plan_abs_path = None
            plan_display_name = ""

        session_exists = tmux_session_exists(args.project_name)
        if session_exists:
            result.session_reused = True
            result.warnings.append(f"session {args.project_name!r} already existed; reusing it")
        elif not args.no_spawn:
            if not args.dry_run:
                run_command(
                    build_spawn_command(args.project_name, cc_count, cod_count, gmi_count, no_user),
                    cwd=project_dir,
                    timeout=180,
                )
            result.session_spawned = True
        elif not args.no_send:
            raise BootstrapError("cannot send the planning prompt without an existing session when --no-spawn is set")

        if plan_abs_path is not None:
            result.prompt_pane = args.pane if args.pane is not None else detect_prompt_pane(args.project_name)

        result.session_attached = handle_post_spawn_interaction(
            session=args.project_name,
            project_dir=project_dir,
            auto_attach=bool(result.session_spawned and auto_attach),
            pane=result.prompt_pane,
            template_name=template_name,
            plan_abs_path=plan_abs_path,
            plan_display_name=plan_display_name,
        )

    except BootstrapError as exc:
        if args.json:
            print(json.dumps({"success": False, "error": str(exc)}, indent=2))
        else:
            print(f"Error: {exc}", file=sys.stderr)
        return 1

    if args.json:
        payload = result.as_dict()
        payload["success"] = True
        payload["dry_run"] = args.dry_run
        print(json.dumps(payload, indent=2))
    else:
        print_summary(result)
    return 0


if __name__ == "__main__":
    sys.exit(main())
