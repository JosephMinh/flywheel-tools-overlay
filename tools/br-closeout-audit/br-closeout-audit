#!/usr/bin/env python3

from __future__ import annotations

import argparse
import fnmatch
import json
import os
import re
import subprocess
import sys
from collections import defaultdict
from copy import deepcopy
from dataclasses import dataclass, field
from functools import lru_cache
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
CONFIG_PATH = SCRIPT_DIR / "config.json"


BACKTICK_PATH_RE = re.compile(r"`([^`\n]+)`")
VERIFY_TITLE_RE = re.compile(r"\b(verify|verification|re-sync|resync|validate)\b", re.I)
SECTION_RE = re.compile(r"^##\s+(.+?)\s*$", re.M)
MIGRATION_RE = re.compile(r"\b(migration|schema|prisma|column|ddl)\b", re.I)


@dataclass
class CommitRecord:
    sha: str
    subject: str
    files: list[str]
    source: str


@dataclass
class Finding:
    severity: str
    code: str
    message: str
    details: list[str] = field(default_factory=list)


@dataclass
class AuditResult:
    issue_id: str
    title: str
    mode: str
    findings: list[Finding]
    direct_commits: list[CommitRecord]
    temporal_commits: list[CommitRecord]
    expected_paths: list[str]

    @property
    def blockers(self) -> int:
        return sum(1 for finding in self.findings if finding.severity == "BLOCKER")

    @property
    def warnings(self) -> int:
        return sum(1 for finding in self.findings if finding.severity == "WARN")


class ToolError(RuntimeError):
    pass


def run_json(cmd: list[str], cwd: str) -> Any:
    proc = subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)
    if proc.returncode != 0:
        raise ToolError(f"command failed: {' '.join(cmd)}\n{proc.stderr.strip()}")
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise ToolError(f"invalid JSON from {' '.join(cmd)}: {exc}") from exc


def run_text(cmd: list[str], cwd: str) -> str:
    proc = subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)
    if proc.returncode != 0:
        raise ToolError(f"command failed: {' '.join(cmd)}\n{proc.stderr.strip()}")
    return proc.stdout


def load_config(path: Path) -> dict[str, Any]:
    with path.open() as handle:
        return json.load(handle)


def resolve_repo(repo_arg: str | None) -> str:
    if repo_arg:
        return os.path.realpath(os.path.expanduser(repo_arg))
    proc = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0:
        raise ToolError("not inside a git repo; pass --repo")
    return os.path.realpath(proc.stdout.strip())


def deep_merge(base: Any, overlay: Any) -> Any:
    if isinstance(base, dict) and isinstance(overlay, dict):
        merged = {key: deepcopy(value) for key, value in base.items()}
        for key, value in overlay.items():
            if key in merged:
                merged[key] = deep_merge(merged[key], value)
            else:
                merged[key] = deepcopy(value)
        return merged
    return deepcopy(overlay)


def project_override_matches(override: dict[str, Any], repo_path: str) -> bool:
    raw_repo_path = str(override.get("repo_path") or "").strip()
    if raw_repo_path and os.path.realpath(os.path.expanduser(raw_repo_path)) == repo_path:
        return True

    repo_name = os.path.basename(repo_path)
    raw_repo_name = str(override.get("repo_name") or "").strip()
    if raw_repo_name and raw_repo_name == repo_name:
        return True

    return False


def resolve_project_policy_files(config: dict[str, Any], repo_path: str) -> list[Path]:
    files: list[Path] = []
    for relative_path in config.get("project_policy_paths", []):
        candidate = Path(repo_path) / relative_path
        if candidate.exists():
            files.append(candidate)
    return files


def resolve_project_policy(config: dict[str, Any], repo_path: str) -> dict[str, Any]:
    defaults = config.get("defaults")
    if not isinstance(defaults, dict):
        raise ToolError("closeout audit config is missing a top-level defaults object")

    policy = deepcopy(defaults)
    for override in config.get("project_overrides", []):
        if isinstance(override, dict) and project_override_matches(override, repo_path):
            policy = deep_merge(policy, override)

    for policy_path in resolve_project_policy_files(config, repo_path):
        policy = deep_merge(policy, load_config(policy_path))

    policy["repo_path"] = repo_path
    policy.setdefault("name", os.path.basename(repo_path))
    return policy


def classify_mode(issue: dict[str, Any], project: dict[str, Any]) -> str:
    labels = set(issue.get("labels") or [])
    title = issue.get("title") or ""
    description = issue.get("description") or ""
    issue_type = issue.get("issue_type") or ""
    label_map = project.get("labels", {})
    if labels & set(label_map.get("verification", [])):
        return "verification"
    if issue_type != "epic" and (labels & set(label_map.get("migration", []))) and (
        MIGRATION_RE.search(title) or MIGRATION_RE.search(description)
    ):
        return "migration"
    if labels & set(label_map.get("test", [])):
        return "test"
    if labels & set(label_map.get("docs", [])):
        return "docs"
    if VERIFY_TITLE_RE.search(title):
        return "verification"
    return "code"


def split_markdown_sections(description: str) -> dict[str, str]:
    description = description or ""
    matches = list(SECTION_RE.finditer(description))
    if not matches:
        return {}
    sections: dict[str, str] = {}
    for index, match in enumerate(matches):
        start = match.end()
        end = matches[index + 1].start() if index + 1 < len(matches) else len(description)
        sections[match.group(1).strip()] = description[start:end].strip()
    return sections


def collect_fileish_backticks(text: str) -> list[str]:
    paths: list[str] = []
    for match in BACKTICK_PATH_RE.findall(text or ""):
        candidate = match.strip()
        if not candidate:
            continue
        if "/" in candidate or candidate.endswith(
            (".ts", ".tsx", ".js", ".jsx", ".py", ".go", ".rs", ".prisma", ".sql", ".md")
        ):
            paths.append(candidate.lstrip("./"))
    return paths


def extract_expected_paths(description: str) -> list[str]:
    sections = split_markdown_sections(description)
    scoped_text = "\n\n".join(
        section_text
        for section_name, section_text in sections.items()
        if section_name.lower() in {"where", "files touched", "what"}
    )
    paths = collect_fileish_backticks(scoped_text)
    if not paths:
        paths = collect_fileish_backticks(description)
    deduped: list[str] = []
    seen: set[str] = set()
    for path in paths:
        if path not in seen:
            deduped.append(path)
            seen.add(path)
    return deduped


def matches_any(path: str, patterns: list[str]) -> bool:
    return any(fnmatch.fnmatch(path, pattern) for pattern in patterns)


def normalize_commit_files(files: list[str]) -> list[str]:
    return [path.strip() for path in files if path and path.strip()]


def parse_git_show_name_only(output: str, source: str) -> list[CommitRecord]:
    commits: list[CommitRecord] = []
    current_sha: str | None = None
    current_subject = ""
    current_files: list[str] = []
    for line in output.splitlines():
        if line.startswith("COMMIT "):
            if current_sha:
                commits.append(
                    CommitRecord(
                        sha=current_sha,
                        subject=current_subject,
                        files=normalize_commit_files(current_files),
                        source=source,
                    )
                )
            current_sha = line.split(" ", 1)[1].strip()
            current_subject = ""
            current_files = []
        elif line.startswith("SUBJECT "):
            current_subject = line.split(" ", 1)[1].strip()
        elif line.strip():
            current_files.append(line.strip())
    if current_sha:
        commits.append(
            CommitRecord(
                sha=current_sha,
                subject=current_subject,
                files=normalize_commit_files(current_files),
                source=source,
            )
        )
    return commits


def dedupe_commits(commits: list[CommitRecord]) -> list[CommitRecord]:
    by_sha: dict[str, CommitRecord] = {}
    for commit in commits:
        if commit.sha in by_sha:
            existing = by_sha[commit.sha]
            merged_files = sorted(set(existing.files) | set(commit.files))
            by_sha[commit.sha] = CommitRecord(
                sha=commit.sha,
                subject=existing.subject or commit.subject,
                files=merged_files,
                source=f"{existing.source},{commit.source}",
            )
        else:
            by_sha[commit.sha] = commit
    return list(by_sha.values())


def commits_from_history(history: dict[str, Any]) -> list[CommitRecord]:
    commits: list[CommitRecord] = []
    for entry in history.get("commits") or []:
        files = [file_entry["path"] for file_entry in entry.get("files") or []]
        commits.append(
            CommitRecord(
                sha=entry["sha"],
                subject=entry.get("message") or "",
                files=normalize_commit_files(files),
                source="bv-history",
            )
        )
    return commits


def commits_from_grep(repo: str, issue_id: str) -> list[CommitRecord]:
    pattern = rf"(?<![A-Za-z0-9_.-]){re.escape(issue_id)}(?![A-Za-z0-9_.-])"
    output = run_text(
        [
            "git",
            "log",
            "--all",
            "--perl-regexp",
            f"--grep={pattern}",
            "--name-only",
            "--format=COMMIT %H%nSUBJECT %s",
        ],
        repo,
    )
    return parse_git_show_name_only(output, "git-grep")


@lru_cache(maxsize=8)
def tracked_files(repo: str) -> list[str]:
    output = run_text(["git", "ls-files"], repo)
    return [line.strip() for line in output.splitlines() if line.strip()]


def resolve_expected_paths(repo: str, paths: list[str]) -> list[str]:
    repo_files = tracked_files(repo)
    resolved: list[str] = []
    seen: set[str] = set()
    for path in paths:
        candidates = []
        if path in repo_files:
            candidates = [path]
        else:
            candidates = [repo_file for repo_file in repo_files if repo_file.endswith("/" + path)]
        chosen = candidates[0] if len(candidates) == 1 else path
        if chosen not in seen:
            resolved.append(chosen)
            seen.add(chosen)
    return resolved


def commits_from_temporal_paths(
    repo: str,
    created_at: str | None,
    closed_at: str | None,
    expected_paths: list[str],
) -> list[CommitRecord]:
    if not created_at or not closed_at or not expected_paths:
        return []
    output = run_text(
        [
            "git",
            "log",
            "--all",
            f"--since={created_at}",
            f"--until={closed_at}",
            "--name-only",
            "--format=COMMIT %H%nSUBJECT %s",
            "--",
            *expected_paths,
        ],
        repo,
    )
    return parse_git_show_name_only(output, "temporal-path")


def non_meta_files(files: list[str], project: dict[str, Any]) -> list[str]:
    meta_globs = project.get("meta_globs", [])
    return [path for path in files if not matches_any(path, meta_globs)]


def close_reason_has_evidence(issue: dict[str, Any], rule: dict[str, Any]) -> bool:
    close_reason = (issue.get("close_reason") or "").lower()
    return any(token.lower() in close_reason for token in rule.get("evidence_tokens", []))


def dependency_blockers(issue: dict[str, Any]) -> list[str]:
    blockers: list[str] = []
    for dep in issue.get("dependencies") or []:
        if dep.get("dependency_type") == "blocks" and dep.get("status") != "closed":
            blockers.append(f"{dep.get('id')} ({dep.get('status')})")
    return blockers


def gather_issue_ids(
    repo: str,
    project: dict[str, Any],
    args: argparse.Namespace,
    histories: dict[str, Any],
) -> list[str]:
    if args.issue:
        return args.issue

    since_rev = args.since_rev or project.get("default_since_rev")
    if since_rev:
        revs = set(run_text(["git", "rev-list", f"{since_rev}..HEAD"], repo).split())
        issue_ids: list[str] = []
        for bead_id, history in histories.items():
            if history.get("status") != "closed":
                continue
            shas = {commit.sha for commit in commits_from_history(history)}
            closed_sha = ((history.get("milestones") or {}).get("closed") or {}).get("commit_sha")
            if closed_sha:
                shas.add(closed_sha)
            if shas & revs:
                issue_ids.append(bead_id)
        return sorted(set(issue_ids))

    closed_histories = [
        history
        for history in histories.values()
        if history.get("status") == "closed"
    ]
    closed_histories.sort(
        key=lambda history: ((history.get("milestones") or {}).get("closed") or {}).get("timestamp") or "",
        reverse=True,
    )
    limit = args.limit or project.get("default_limit", 10)
    return [history["bead_id"] for history in closed_histories[:limit]]


def touched_matches_expected(files: list[str], expected_paths: list[str]) -> bool:
    if not expected_paths:
        return False
    for path in files:
        for expected in expected_paths:
            if path == expected or path.endswith("/" + expected) or expected.endswith("/" + path):
                return True
    return False


def touched_matches_globs(files: list[str], globs: list[str]) -> bool:
    return any(matches_any(path, globs) for path in files)


def audit_issue(
    repo: str,
    project: dict[str, Any],
    issue: dict[str, Any],
    history: dict[str, Any] | None,
) -> AuditResult:
    mode = classify_mode(issue, project)
    description = issue.get("description") or ""
    expected_paths = resolve_expected_paths(repo, extract_expected_paths(description))

    direct_commits = dedupe_commits(
        commits_from_history(history or {}) + commits_from_grep(repo, issue["id"])
    )
    temporal_commits = dedupe_commits(
        commits_from_temporal_paths(
            repo,
            issue.get("created_at"),
            issue.get("closed_at"),
            expected_paths,
        )
    )

    direct_files = sorted({path for commit in direct_commits for path in commit.files})
    temporal_files = sorted({path for commit in temporal_commits for path in commit.files})
    direct_non_meta = non_meta_files(direct_files, project)
    temporal_non_meta = non_meta_files(temporal_files, project)

    findings: list[Finding] = []

    blockers = dependency_blockers(issue)
    if blockers:
        findings.append(
            Finding(
                severity="BLOCKER",
                code="open_blocker_dependencies",
                message="issue was closed while blocker dependencies were still open",
                details=blockers,
            )
        )

    if mode != "docs" and not direct_commits and not temporal_commits:
        findings.append(
            Finding(
                severity="BLOCKER",
                code="no_commit_evidence",
                message="no correlated or temporal implementation evidence was found for the closed bead",
            )
        )

    if direct_commits and not direct_non_meta and not temporal_non_meta:
        findings.append(
            Finding(
                severity="BLOCKER",
                code="meta_only_commits",
                message="all linked commits touched only tracker/meta paths",
                details=direct_files,
            )
        )

    if expected_paths:
        direct_path_match = touched_matches_expected(direct_non_meta, expected_paths)
        temporal_path_match = touched_matches_expected(temporal_non_meta, expected_paths)
        if not direct_path_match and not temporal_path_match:
            findings.append(
                Finding(
                    severity="BLOCKER",
                    code="expected_paths_not_touched",
                    message="no evidence touched the file paths named in the bead description",
                    details=expected_paths,
                )
            )
        elif temporal_path_match and not direct_path_match:
            temporal_details = [
                f"{commit.sha[:7]} {commit.subject}"
                for commit in temporal_commits
                if touched_matches_expected(commit.files, expected_paths)
            ]
            findings.append(
                Finding(
                    severity="BLOCKER",
                    code="unlinked_path_evidence",
                    message="implementation evidence exists in the issue time window, but the closeout was not linked to it",
                    details=temporal_details[:5],
                )
            )

    mode_rule = (project.get("mode_rules") or {}).get(mode, {})
    for path_set in mode_rule.get("require_path_sets", []):
        label = path_set["label"]
        globs = path_set["globs"]
        if not touched_matches_globs(direct_non_meta + temporal_non_meta, globs):
            findings.append(
                Finding(
                    severity="BLOCKER",
                    code=f"missing_required_path_set_{label}",
                    message=f"{mode} bead lacks required {label} evidence",
                    details=globs,
                )
            )

    if mode_rule.get("require_any_globs"):
        if not touched_matches_globs(direct_non_meta + temporal_non_meta, mode_rule["require_any_globs"]):
            findings.append(
                Finding(
                    severity="BLOCKER",
                    code="missing_mode_specific_evidence",
                    message=f"{mode} bead lacks expected file evidence",
                    details=mode_rule["require_any_globs"],
                )
            )

    if mode_rule.get("require_close_reason_evidence") and not close_reason_has_evidence(issue, mode_rule):
        findings.append(
            Finding(
                severity="BLOCKER",
                code="missing_close_reason_evidence",
                message="verification bead close reason does not include explicit evidence",
                details=[issue.get("close_reason") or "(empty close reason)"],
            )
        )

    closed_milestone = ((history or {}).get("milestones") or {}).get("closed") or {}
    close_subject = (closed_milestone.get("commit_message") or "").lower()
    if close_subject and any(
        close_subject.startswith(prefix.lower())
        for prefix in project.get("close_commit_meta_prefixes", [])
    ):
        findings.append(
            Finding(
                severity="WARN" if direct_non_meta else "BLOCKER",
                code="meta_close_commit",
                message="issue was closed in a tracker/meta commit rather than a clearly relevant implementation commit",
                details=[closed_milestone.get("commit_message") or ""],
            )
        )

    return AuditResult(
        issue_id=issue["id"],
        title=issue["title"],
        mode=mode,
        findings=findings,
        direct_commits=direct_commits,
        temporal_commits=temporal_commits,
        expected_paths=expected_paths,
    )


def format_text(results: list[AuditResult], repo: str) -> str:
    lines = [f"Repo: {repo}", f"Audited issues: {len(results)}", ""]
    blocker_count = sum(result.blockers for result in results)
    warn_count = sum(result.warnings for result in results)
    lines.append(f"Summary: {blocker_count} blocker(s), {warn_count} warning(s)")
    lines.append("")

    for result in results:
        status = "PASS"
        if result.blockers:
            status = "BLOCKER"
        elif result.warnings:
            status = "WARN"
        lines.append(f"{status} {result.issue_id} [{result.mode}] {result.title}")
        if result.expected_paths:
            lines.append("  expected paths:")
            for path in result.expected_paths[:6]:
                lines.append(f"    - {path}")
        if result.direct_commits:
            lines.append("  linked commits:")
            for commit in result.direct_commits[:5]:
                lines.append(f"    - {commit.sha[:7]} {commit.subject} [{commit.source}]")
        if result.temporal_commits:
            lines.append("  temporal path evidence:")
            for commit in result.temporal_commits[:5]:
                lines.append(f"    - {commit.sha[:7]} {commit.subject}")
        if not result.findings:
            lines.append("  - no findings")
        else:
            for finding in result.findings:
                lines.append(f"  - {finding.severity} {finding.code}: {finding.message}")
                for detail in finding.details[:6]:
                    lines.append(f"      {detail}")
        lines.append("")
    return "\n".join(lines).rstrip() + "\n"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Audit Beads closeout evidence")
    parser.add_argument("--repo", help="Repo root to audit; defaults to current git repo")
    parser.add_argument(
        "--issue",
        action="append",
        help="Specific bead ID to audit; can be repeated",
    )
    parser.add_argument(
        "--since-rev",
        help="Audit closed issues with evidence in REV..HEAD",
    )
    parser.add_argument(
        "--limit",
        type=int,
        help="When not using --issue or --since-rev, audit the most recent N closed issues",
    )
    parser.add_argument(
        "--format",
        choices=["text", "json"],
        default="text",
        help="Output format",
    )
    parser.add_argument(
        "--config",
        default=str(CONFIG_PATH),
        help="Path to config JSON",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    config = load_config(Path(args.config))
    repo = resolve_repo(args.repo)
    project = resolve_project_policy(config, repo)

    histories_payload = run_json(["bv", "--robot-history"], repo)
    raw_histories = histories_payload.get("histories", {})
    if isinstance(raw_histories, list):
        histories = {
            history["bead_id"]: history
            for history in raw_histories
            if isinstance(history, dict) and history.get("bead_id")
        }
    elif isinstance(raw_histories, dict):
        histories = {
            bead_id: history
            for bead_id, history in raw_histories.items()
            if isinstance(history, dict)
        }
    else:
        raise ToolError("unsupported bv --robot-history payload shape")

    issue_ids = gather_issue_ids(repo, project, args, histories)
    if not issue_ids:
        raise ToolError("no closed issues matched the audit selection")

    issues_by_id: dict[str, dict[str, Any]] = {}
    for issue_id in issue_ids:
        payload = run_json(["br", "show", "--json", issue_id], repo)
        if not payload:
            raise ToolError(f"issue not found: {issue_id}")
        issues_by_id[issue_id] = payload[0]

    results = [
        audit_issue(repo, project, issues_by_id[issue_id], histories.get(issue_id))
        for issue_id in issue_ids
    ]

    if args.format == "json":
        serializable = {
            "repo": repo,
            "summary": {
                "issues_audited": len(results),
                "blockers": sum(result.blockers for result in results),
                "warnings": sum(result.warnings for result in results),
            },
            "results": [
                {
                    "issue_id": result.issue_id,
                    "title": result.title,
                    "mode": result.mode,
                    "expected_paths": result.expected_paths,
                    "direct_commits": [
                        {
                            "sha": commit.sha,
                            "subject": commit.subject,
                            "files": commit.files,
                            "source": commit.source,
                        }
                        for commit in result.direct_commits
                    ],
                    "temporal_commits": [
                        {
                            "sha": commit.sha,
                            "subject": commit.subject,
                            "files": commit.files,
                            "source": commit.source,
                        }
                        for commit in result.temporal_commits
                    ],
                    "findings": [
                        {
                            "severity": finding.severity,
                            "code": finding.code,
                            "message": finding.message,
                            "details": finding.details,
                        }
                        for finding in result.findings
                    ],
                }
                for result in results
            ],
        }
        print(json.dumps(serializable, indent=2))
    else:
        sys.stdout.write(format_text(results, repo))

    return 1 if any(result.blockers for result in results) else 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except ToolError as exc:
        print(f"error: {exc}", file=sys.stderr)
        raise SystemExit(2)
