def command_status(config: Config) -> int:
    panes = list_tmux_panes()
    bindings = load_bindings(config).get("bindings", {})
    binding_statuses: dict[str, Any] = {}
    env_cache: dict[int, dict[str, str]] = {}
    tree_cache: dict[int, list[int]] = {}
    work_state_cache: dict[str, ProjectWorkState] = {}
    suppress_decisions = frozenset({
        POLICY_DECISION_SUPPRESS_NO_OPEN,
        POLICY_DECISION_SUPPRESS_NO_READY,
    })
    for key, binding in bindings.items():
        pane = resolve_bound_pane(binding, panes)
        loose_pane = resolve_bound_pane_loose(binding, panes)
        entry = dict(binding) if isinstance(binding, dict) else {"raw": binding}
        prompt_state = None
        state_reason = None
        provider_identity_issue = None
        wake_deliverable = False
        if pane is not None:
            prompt_state, state_reason, _ = classify_pane_prompt_state_stable(pane)
            provider_identity_issue = provider_identity_issue_reason(
                pane,
                project_key=str(entry.get("project_key") or "").strip(),
                program=str(entry.get("program") or "").strip(),
                panes=panes,
                env_cache=env_cache,
                tree_cache=tree_cache,
            )
            wake_deliverable = (
                prompt_state in {"idle_prompt", "awaiting_input"} and provider_identity_issue is None
            )
            if provider_identity_issue:
                state_reason = provider_identity_issue
        elif loose_pane is None:
            prompt_state = "dead"
            state_reason = "no-live-pane"
        binding_project_key = str(entry.get("project_key") or "").strip()
        if binding_project_key:
            work_state = project_work_state_for_target(
                pane, binding_project_key, work_state_cache
            )
        else:
            work_state = ProjectWorkState.unavailable(
                repo_root=None,
                source="canonical-project",
                error="no-project-key",
            )
        entry["pane_live"] = pane is not None
        entry["pane_loose_live"] = loose_pane is not None
        entry["alive"] = pane is not None
        entry["prompt_state"] = prompt_state
        entry["state_reason"] = state_reason
        entry["ownership_conflict_reason"] = provider_identity_issue
        entry["provider_identity_issue_reason"] = provider_identity_issue
        entry["wake_deliverable"] = wake_deliverable
        entry["resolved_pane_key"] = pane.composite_key if pane is not None else None
        entry["resolved_pane_id"] = pane.pane_id if pane is not None else None
        entry["resolved_session_name"] = pane.session_name if pane is not None else None
        entry["resolved_current_path"] = pane.current_path if pane is not None else None
        entry["loose_pane_key"] = loose_pane.composite_key if loose_pane is not None else None
        entry["loose_pane_id"] = loose_pane.pane_id if loose_pane is not None else None
        entry["work_state_repo_root"] = (
            str(work_state.repo_root) if work_state.repo_root is not None else None
        )
        entry["work_state_source"] = work_state.source
        entry["work_state_available"] = work_state.available
        entry["work_state_open_count"] = work_state.open_count
        entry["work_state_ready_count"] = work_state.ready_count
        entry["work_state_in_progress_count"] = work_state.in_progress_count
        entry["work_state_error"] = work_state.error
        if config.beads_gate_enabled:
            entry["normal_wake_allowed"] = (
                beads_gate_decision("normal", work_state)[0] not in suppress_decisions
            )
            entry["high_wake_allowed"] = (
                beads_gate_decision("high", work_state)[0] not in suppress_decisions
            )
            entry["urgent_wake_allowed"] = (
                beads_gate_decision("urgent", work_state)[0] not in suppress_decisions
            )
        else:
            entry["normal_wake_allowed"] = True
            entry["high_wake_allowed"] = True
            entry["urgent_wake_allowed"] = True
        entry["beads_gate_explanation"] = beads_gate_status_explanation(
            config, work_state
        )
        binding_statuses[key] = entry
    payload = {
        "config": config.to_json(),
        "pending_signal_paths": [str(path) for path in iter_signal_paths(config)],
        "bindings": bindings,
        "binding_statuses": binding_statuses,
        "tmux_panes": [
            {
                "session_name": pane.session_name,
                "window_index": pane.window_index,
