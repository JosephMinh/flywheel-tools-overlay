        encoding="utf-8",
    )
    agent_dir.mkdir(parents=True, exist_ok=True)
    (agent_dir / "profile.json").write_text(
        json.dumps({"name": agent_name, "program": program}, indent=2),
        encoding="utf-8",
    )


def setup_self_test_beads_repo(workspace: pathlib.Path) -> pathlib.Path:
    workspace.mkdir(parents=True, exist_ok=True)
    if not (workspace / ".git").is_dir():
        run_command(["git", "init", "-q"], cwd=workspace)
    if not (workspace / ".beads").is_dir():
        run_command(["br", "init"], cwd=workspace)
    return workspace


SELF_TEST_BEADS_SCENARIOS = ("zero-open", "open-zero-ready", "ready")
SELF_TEST_BEADS_EXPECTED_COUNTS: dict[str, dict[str, int]] = {
    "zero-open": {"open_count": 0, "ready_count": 0},
    "open-zero-ready": {"open_count": 1, "ready_count": 0},
    "ready": {"open_count": 1, "ready_count": 1},
}


def seed_self_test_beads_state(
    repo_root: pathlib.Path,
    scenario: str,
) -> dict[str, int]:
    if scenario not in SELF_TEST_BEADS_EXPECTED_COUNTS:
        raise ValueError(
            f"unknown self-test beads scenario {scenario!r}; "
            f"expected one of {SELF_TEST_BEADS_SCENARIOS}"
        )
    if scenario == "zero-open":
        create_result = run_command(
            ["br", "--json", "create", "self-test seed (zero-open)", "-p", "1"],
            cwd=repo_root,
        )
        issue_id = json.loads(create_result.stdout)["id"]
        run_command(
            ["br", "close", issue_id, "-r", "self-test seed (zero-open)"],
            cwd=repo_root,
        )
    elif scenario == "open-zero-ready":
        # Defer at create time so the issue is open but never ready.
        run_command(
            [
                "br",
                "create",
                "self-test seed (open-zero-ready)",
                "-p",
                "1",
                "--defer",
                "+30d",
            ],
            cwd=repo_root,
        )
    else:
        run_command(
            ["br", "create", "self-test seed (ready)", "-p", "1"],
            cwd=repo_root,
        )

    stats_result = run_command(
        ["br", "--json", "--no-auto-flush", "--no-auto-import", "stats"],
        cwd=repo_root,
    )
    summary = json.loads(stats_result.stdout or "{}").get("summary") or {}
    counts = {
        "open_count": parse_int(summary.get("open_issues", 0), 0),
        "ready_count": parse_int(summary.get("ready_issues", 0), 0),
        "in_progress_count": parse_int(summary.get("in_progress_issues", 0), 0),
    }
    for key, want in SELF_TEST_BEADS_EXPECTED_COUNTS[scenario].items():
        if counts[key] != want:
            raise RuntimeError(
                f"self-test seed {scenario}: {key}={counts[key]}, expected {want} "
                f"(full counts: {counts})"
            )
    return counts


SELF_TEST_BEADS_UNAVAILABLE_SCENARIOS = ("no-beads-dir",)
SELF_TEST_BEADS_UNAVAILABLE_EXPECTED_ERROR: dict[str, str] = {
    "no-beads-dir": "beads-repo-not-found",
}


def setup_self_test_unavailable_workspace(
    workspace: pathlib.Path,
    *,
    scenario: str = "no-beads-dir",
) -> pathlib.Path:
    if scenario not in SELF_TEST_BEADS_UNAVAILABLE_SCENARIOS:
        raise ValueError(
            f"unknown unavailable scenario {scenario!r}; "
            f"expected one of {SELF_TEST_BEADS_UNAVAILABLE_SCENARIOS}"
        )
    workspace.mkdir(parents=True, exist_ok=True)
    if not (workspace / ".git").is_dir():
        run_command(["git", "init", "-q"], cwd=workspace)
    # Intentionally do NOT run `br init` for "no-beads-dir": the absence of
    # `.beads/` at the resolved Git root is what makes find_beads_repo_root
    # return None, which maps to ProjectWorkState.unavailable(error=
    # "beads-repo-not-found") in project_work_state_for_target. That state
    # then drives beads_gate_decision to POLICY_DECISION_SKIP_UNAVAILABLE,
    # exercising the watcher's fail-open path without depending on PATH
    # manipulation, lock contention, or other fragile global state.
    return workspace


def create_self_test_pane(
    *,
    session_name: str,
    workspace: pathlib.Path,
    shell_command: str,
) -> PaneInfo:
    run_command(
        [
            "tmux",
            "new-session",
            "-d",
            "-s",
            session_name,
            "-n",
            "wake",
            "-c",
            str(workspace),
            shell_command,
        ]
    )
    panes = [pane for pane in list_tmux_panes() if pane.composite_key.startswith(f"{session_name}:")]
    if not panes:
        raise RuntimeError(f"self-test could not create tmux session {session_name}")
    return panes[0]


def create_self_test_provider_pane(
    *,
    session_name: str,
    workspace: pathlib.Path,
    program: str,
) -> PaneInfo:
    result = run_command(
        [
            "tmux",
            "new-session",
            "-d",
            "-s",
            session_name,
            "-n",
            "wake",
            "-c",
            str(workspace),
            "-P",
            "-F",
            "#{pane_id}",
            "python3",
            "-u",
            "-c",
            program,
        ]
    )
    pane_id = result.stdout.strip()
    pane = tmux_pane_by_id(pane_id)
    if pane is None:
        raise RuntimeError(f"self-test failed to create provider pane for {session_name}")
    return pane


