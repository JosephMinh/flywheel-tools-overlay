def iso_utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat()


def parse_iso_timestamp(value: str) -> dt.datetime | None:
    candidate = value.strip()
    if not candidate:
        return None
    if candidate.endswith("Z"):
        candidate = candidate[:-1] + "+00:00"
    try:
        parsed = dt.datetime.fromisoformat(candidate)
    except ValueError:
        return None
    if parsed.tzinfo is None:
        return parsed.replace(tzinfo=dt.timezone.utc)
    return parsed


def sanitize_pane_id(pane_id: str) -> str:
    stripped = pane_id[1:] if pane_id.startswith("%") else pane_id
    output: list[str] = []
    for ch in stripped:
        if ch.isascii() and (ch.isalnum() or ch in "-_"):
            output.append(ch)
        elif ch == ":":
            output.append("-")
        else:
            output.append("_")
    return "".join(output) or "unknown"


def project_hash(project_key: str) -> str:
    return hashlib.sha1(project_key.encode("utf-8")).hexdigest()[:12]


