@dataclass
class Config:
    config_path: pathlib.Path
    signals_dir: pathlib.Path
    mailbox_root: pathlib.Path
    state_path: pathlib.Path
    log_path: pathlib.Path
    lock_path: pathlib.Path
    bindings_path: pathlib.Path
    poll_interval_seconds: float
    deferred_retry_seconds: float
    max_retry_attempts: int
    max_event_log_lines: int
    wake_prompt_template: str
    create_session_prefix: str
    shell_command: str
    auto_create_missing_panes: bool
    beads_gate_enabled: bool
    provider_specs: dict[str, ProviderSpec]

    @classmethod
    def load(cls, path: pathlib.Path) -> "Config":
        raw = read_json(path, {})
        provider_specs = dict(DEFAULT_PROVIDER_SPECS)
        for program, payload in raw.get("providers", {}).items():
            provider_specs[program] = ProviderSpec(
                active_commands=tuple(payload.get("active_commands", ())),
                title_markers=tuple(payload.get("title_markers", ())),
                launch_template=str(payload["launch_template"]),
                resume_template=payload.get("resume_template"),
                session_lookup_provider=payload.get("session_lookup_provider"),
            )
        return cls(
            config_path=path,
            signals_dir=pathlib.Path(raw.get("signals_dir", str(DEFAULT_SIGNALS_DIR))).expanduser(),
            mailbox_root=pathlib.Path(raw.get("mailbox_root", str(DEFAULT_MAILBOX_ROOT))).expanduser(),
            state_path=pathlib.Path(raw.get("state_path", str(DEFAULT_STATE_PATH))).expanduser(),
            log_path=pathlib.Path(raw.get("log_path", str(DEFAULT_LOG_PATH))).expanduser(),
            lock_path=pathlib.Path(raw.get("lock_path", str(DEFAULT_LOCK_PATH))).expanduser(),
            bindings_path=pathlib.Path(raw.get("bindings_path", str(DEFAULT_BINDINGS_PATH))).expanduser(),
            poll_interval_seconds=float(raw.get("poll_interval_seconds", 1.0)),
            deferred_retry_seconds=float(raw.get("deferred_retry_seconds", 2.0)),
            max_retry_attempts=max(0, parse_int(raw.get("max_retry_attempts", 5), 5)),
            max_event_log_lines=max(1, parse_int(raw.get("max_event_log_lines", 5000), 5000)),
            wake_prompt_template=str(
                raw.get(
                    "wake_prompt_template",
                    (
                        "Agent Mail wake-up for {agent_name} in {project_key}. "
                        "New {importance} message from {sender}: {subject}. "
                        "Fetch your inbox, acknowledge/respond if needed, and continue the next "
                        "unblocked work you were waiting on."
                    ),
                )
            ),
            create_session_prefix=str(raw.get("create_session_prefix", "agentmail")),
            shell_command=str(raw.get("shell_command", "zsh -l")),
            auto_create_missing_panes=bool(raw.get("auto_create_missing_panes", False)),
            beads_gate_enabled=bool(raw.get("beads_gate_enabled", False)),
            provider_specs=provider_specs,
        )

    def to_json(self) -> dict[str, Any]:
        return {
            "signals_dir": str(self.signals_dir),
            "mailbox_root": str(self.mailbox_root),
            "state_path": str(self.state_path),
            "log_path": str(self.log_path),
