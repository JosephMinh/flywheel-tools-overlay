@contextmanager
def acquire_scan_lock(config: Config, *, blocking: bool) -> Any:
    ensure_parent(config.lock_path)
    with config.lock_path.open("a+", encoding="utf-8") as handle:
        flags = fcntl.LOCK_EX
        if not blocking:
            flags |= fcntl.LOCK_NB
        try:
            fcntl.flock(handle.fileno(), flags)
        except BlockingIOError as exc:
            raise RuntimeError(f"watcher lock is already held at {config.lock_path}") from exc
        try:
            handle.seek(0)
            handle.truncate()
            handle.write(f"{os.getpid()} {iso_utc_now()}\n")
            handle.flush()
            yield handle
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


