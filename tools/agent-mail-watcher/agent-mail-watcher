def list_tmux_panes() -> list[PaneInfo]:
    if not tmux_available():
        return []
    result = run_command(
        [
            "tmux",
            "list-panes",
            "-a",
            "-F",
            "#{session_name}\t#{window_index}\t#{pane_index}\t#{pane_id}\t"
            "#{pane_active}\t#{pane_current_command}\t#{pane_title}\t#{pane_current_path}\t#{pane_pid}\t#{pane_dead}\t"
            "#{@agent_mail_agent_name}\t#{@agent_mail_project_key}\t#{@agent_mail_project_hash}\t"
            "#{@agent_mail_binding_nonce}\t#{@agent_mail_program}\t#{@agent_mail_session_id}\t#{@agent_mail_pane_key}",
        ]
    )
    panes: list[PaneInfo] = []
    for line in result.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) != 17:
            continue
        (
            session_name,
            window_index,
            pane_index,
            pane_id,
            active,
            command,
            title,
            current_path,
            pid,
            dead,
            bound_agent_name,
            bound_project_key,
            bound_project_hash,
            bound_binding_nonce,
            bound_program,
            bound_session_id,
            bound_pane_key,
        ) = parts
        panes.append(
            PaneInfo(
                session_name=session_name,
                window_index=window_index,
                pane_index=pane_index,
                composite_key=f"{session_name}:{window_index}:{pane_index}",
                pane_id=pane_id,
                active=active == "1",
                current_command=command.strip(),
                title=title.strip(),
                current_path=current_path.strip(),
                pid=int(pid) if pid.isdigit() else 0,
                dead=dead == "1",
                bound_agent_name=bound_agent_name.strip(),
                bound_project_key=bound_project_key.strip(),
                bound_project_hash=bound_project_hash.strip(),
                bound_binding_nonce=bound_binding_nonce.strip(),
                bound_program=bound_program.strip(),
                bound_session_id=bound_session_id.strip(),
                bound_pane_key=bound_pane_key.strip(),
            )
        )
    return panes


def canonical_identity_path(project_key: str, pane_key: str) -> pathlib.Path:
    return IDENTITY_ROOT / project_hash(project_key) / sanitize_pane_id(pane_key)


def write_identity(project_key: str, pane_key: str, agent_name: str) -> pathlib.Path:
    path = canonical_identity_path(project_key, pane_key)
    ensure_parent(path)
    path.write_text(f"{agent_name.strip()}\n", encoding="utf-8")
    return path


def normalize_agent_mail_url(url: str) -> str:
    normalized = (url or DEFAULT_AGENT_MAIL_URL).strip() or DEFAULT_AGENT_MAIL_URL
    if not normalized.endswith("/"):
        normalized += "/"
    return normalized


def agent_mail_endpoint(url: str) -> tuple[str, int]:
    parsed = urllib.parse.urlparse(normalize_agent_mail_url(url))
    host = parsed.hostname or "127.0.0.1"
    if parsed.port is not None:
        return host, parsed.port
    return host, 443 if parsed.scheme == "https" else 80


def agent_mail_port_reachable(url: str, *, timeout_seconds: float = 0.75) -> bool:
    host, port = agent_mail_endpoint(url)
    try:
        with socket.create_connection((host, port), timeout=timeout_seconds):
            return True
    except OSError:
        return False


def agent_mail_service_manageable(url: str) -> bool:
    host, _port = agent_mail_endpoint(url)
    if host not in {"127.0.0.1", "localhost"}:
        return False
    try:
        result = run_command(
            ["systemctl", "--user", "show", DEFAULT_AGENT_MAIL_SERVICE, "-p", "LoadState"],
            check=False,
        )
    except FileNotFoundError:
        return False
    return "LoadState=loaded" in result.stdout


def ensure_agent_mail_service_available(config: Config) -> None:
    global _LAST_AGENT_MAIL_RESTORE_ATTEMPT

    agent_mail_url = normalize_agent_mail_url(DEFAULT_AGENT_MAIL_URL)
    if agent_mail_port_reachable(agent_mail_url):
        return
    if not agent_mail_service_manageable(agent_mail_url):
        return

    now = time.monotonic()
    if now - _LAST_AGENT_MAIL_RESTORE_ATTEMPT < AGENT_MAIL_RESTORE_RETRY_SECONDS:
        return
    _LAST_AGENT_MAIL_RESTORE_ATTEMPT = now

    result = run_command(
        ["systemctl", "--user", "start", DEFAULT_AGENT_MAIL_SERVICE],
        check=False,
    )
    restored = False
    deadline = time.monotonic() + 8.0
    while time.monotonic() < deadline:
        if agent_mail_port_reachable(agent_mail_url):
            restored = True
            break
        time.sleep(0.2)

    event = {
        "timestamp": iso_utc_now(),
        "action": "restored-agent-mail-service" if restored else "failed-agent-mail-service-restore",
        "service_name": DEFAULT_AGENT_MAIL_SERVICE,
        "agent_mail_url": agent_mail_url,
        "exit_code": result.returncode,
        "stdout": (result.stdout or "").strip(),
        "stderr": (result.stderr or "").strip(),
        "delivered": restored,
    }
    log_event(config, event)


def extract_mcp_content(raw_result: Any) -> Any:
    if not isinstance(raw_result, dict):
        return raw_result
    structured = raw_result.get("structuredContent")
    if structured is not None:
        return structured
    content = raw_result.get("content")
    if isinstance(content, list):
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") != "text":
                continue
            text = block.get("text")
            if not isinstance(text, str):
                continue
            try:
                return json.loads(text)
            except json.JSONDecodeError:
                return text
    return raw_result


def call_agent_mail_tool(tool_name: str, arguments: dict[str, Any] | None = None) -> Any:
    payload = {
        "jsonrpc": "2.0",
        "id": f"watcher-{tool_name}-{int(time.time() * 1000)}",
        "method": "tools/call",
        "params": {
            "name": tool_name,
            "arguments": arguments or {},
        },
    }
    request = urllib.request.Request(
        normalize_agent_mail_url(DEFAULT_AGENT_MAIL_URL),
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    token = DEFAULT_AGENT_MAIL_TOKEN.strip()
    if token:
        request.add_header("Authorization", f"Bearer {token}")
    with urllib.request.urlopen(request, timeout=5) as response:
        envelope = json.loads(response.read().decode("utf-8"))
    if not isinstance(envelope, dict):
        raise RuntimeError(f"agent mail {tool_name} returned invalid JSON-RPC payload")
    if envelope.get("error"):
        raise RuntimeError(f"agent mail {tool_name} failed: {envelope['error']}")
    return extract_mcp_content(envelope.get("result"))


def ensure_agent_mail_project(project_key: str) -> dict[str, Any]:
    result = call_agent_mail_tool("ensure_project", {"human_key": project_key})
    return result if isinstance(result, dict) else {}


def list_agent_mail_agents(project_key: str) -> list[dict[str, Any]]:
    result = call_agent_mail_tool("list_agents", {"project_key": project_key})
    return result if isinstance(result, list) else []


def create_agent_mail_identity(*, project_key: str, program: str, model: str, task_description: str) -> dict[str, Any]:
    result = call_agent_mail_tool(
        "create_agent_identity",
        {
            "project_key": project_key,
            "program": program,
            "model": model,
            "task_description": task_description,
        },
    )
    if not isinstance(result, dict):
        raise RuntimeError("agent mail create_agent_identity returned invalid payload")
    return result


def register_agent_mail_identity(
    *,
    project_key: str,
    program: str,
    model: str,
    agent_name: str,
    task_description: str,
) -> dict[str, Any]:
    result = call_agent_mail_tool(
        "register_agent",
        {
            "project_key": project_key,
            "program": program,
            "model": model,
            "name": agent_name,
            "task_description": task_description,
        },
    )
    if not isinstance(result, dict):
        raise RuntimeError("agent mail register_agent returned invalid payload")
    return result


def parse_ntm_worker_pane(pane: PaneInfo) -> NTMWorkerPane | None:
    match = NTM_PANE_TITLE_RE.match(pane.title)
    if not match:
        return None
    agent_type = match.group(1).strip()
    if not agent_type or agent_type == "user":
        return None
    provider_program = NTM_AGENT_TYPE_TO_PROGRAM.get(agent_type, agent_type)
    model_hint = (match.group(3) or "").strip() or DEFAULT_MODEL_BY_PROGRAM.get(provider_program, "default")
    return NTMWorkerPane(
        pane=pane,
        agent_type=agent_type,
        provider_program=provider_program,
        model_hint=model_hint,
    )


def registry_from_payload(payload: dict[str, Any] | None, *, session_name: str, project_key: str, path: pathlib.Path) -> NTMRegistry:
    payload = payload or {}
    registered_at = str(payload.get("registered_at") or iso_utc_now())
    updated_at = str(payload.get("updated_at") or registered_at)
    return NTMRegistry(
        session_name=str(payload.get("session_name") or session_name),
        project_key=str(payload.get("project_key") or project_key),
        agents=dict(payload.get("agents") or {}),
        pane_id_map=dict(payload.get("pane_id_map") or {}),
        registered_at=registered_at,
        updated_at=updated_at,
        path=path,
    )


def save_ntm_registry(registry: NTMRegistry) -> None:
    registry.updated_at = iso_utc_now()
    payload = {
        "session_name": registry.session_name,
        "project_key": registry.project_key,
        "agents": registry.agents,
        "pane_id_map": registry.pane_id_map,
        "registered_at": registry.registered_at,
        "updated_at": registry.updated_at,
    }
    write_json_atomic(registry.path, payload)
    registry.path.chmod(0o600)


def registry_add_agent(registry: NTMRegistry, *, pane_title: str, pane_id: str, agent_name: str) -> bool:
    changed = False
    if pane_title:
        for existing_title, existing_agent in list(registry.agents.items()):
            if existing_agent == agent_name and existing_title != pane_title:
                registry.agents.pop(existing_title, None)
                changed = True
        if registry.agents.get(pane_title) != agent_name:
            registry.agents[pane_title] = agent_name
            changed = True
    if pane_id:
        for existing_pane_id, existing_agent in list(registry.pane_id_map.items()):
            if existing_agent == agent_name and existing_pane_id != pane_id:
                registry.pane_id_map.pop(existing_pane_id, None)
                changed = True
        if registry.pane_id_map.get(pane_id) != agent_name:
            registry.pane_id_map[pane_id] = agent_name
            changed = True
    return changed


def registry_agent_name(registry: NTMRegistry, pane: PaneInfo) -> str:
    return (
        str(registry.pane_id_map.get(pane.pane_id) or "").strip()
        or str(registry.agents.get(pane.title) or "").strip()
    )


def iter_ntm_registry_paths() -> list[pathlib.Path]:
    candidates: list[pathlib.Path] = []
    seen: set[str] = set()
    for base in NTM_SESSIONS_DIRS:
        if not base.is_dir():
            continue
        for path in itertools.chain(
            base.glob("*/agent_registry.json"),
            base.glob("*/*/agent_registry.json"),
            base.glob("*/agent.json"),
            base.glob("*/*/agent.json"),
        ):
            key = str(path)
            if key in seen:
                continue
            seen.add(key)
            candidates.append(path)
    return sorted(candidates)


def load_ntm_session_contexts() -> list[tuple[str, str, NTMRegistry]]:
    contexts: dict[tuple[str, str], dict[str, Any]] = {}
    for path in iter_ntm_registry_paths():
        session_name = ""
        for base in NTM_SESSIONS_DIRS:
            try:
                relative = path.relative_to(base)
            except ValueError:
                continue
            if relative.parts:
                session_name = relative.parts[0]
                break
        if not session_name:
            continue
        payload = read_json(path, {})
        if not isinstance(payload, dict):
            continue
        project_key = str(payload.get("project_key") or "").strip()
        if not project_key:
            continue
        key = (session_name, project_key)
        entry = contexts.setdefault(
            key,
            {
                "coordinator_agent_name": "",
                "registry_path": path.parent / "agent_registry.json",
                "registry_payload": None,
            },
        )
        if path.name == "agent.json":
            entry["coordinator_agent_name"] = str(payload.get("agent_name") or "").strip()
            entry["registry_path"] = path.parent / "agent_registry.json"
        elif path.name == "agent_registry.json":
            entry["registry_payload"] = payload
            entry["registry_path"] = path
    resolved: list[tuple[str, str, NTMRegistry]] = []
    for (session_name, project_key), entry in sorted(contexts.items()):
        registry = registry_from_payload(
            entry.get("registry_payload"),
            session_name=session_name,
            project_key=project_key,
            path=entry["registry_path"],
        )
        resolved.append((entry.get("coordinator_agent_name", ""), project_key, registry))
    return resolved


def task_description_for_ntm_worker(session_name: str, pane: PaneInfo, program: str) -> str:
    return f"NTM-managed {program} worker in session {session_name} ({pane.title or pane.composite_key})"


def reconcile_ntm_agent_mail(config: Config, *, panes: list[PaneInfo]) -> None:
    if not panes:
        return
    contexts = load_ntm_session_contexts()
    if not contexts:
        return
    agents_by_project: dict[str, dict[str, dict[str, Any]] | None] = {}
    bindings_map = load_bindings(config).get("bindings", {})
    for _coordinator_name, project_key, registry in contexts:
        session_panes = [
            pane for pane in panes
            if not pane.dead
            and not pane_has_shadow_session_name(config, pane)
            and pane.session_name == registry.session_name
            and path_is_within_project(pane.current_path, project_key)
        ]
        if not session_panes:
            continue
        worker_panes = [candidate for candidate in (parse_ntm_worker_pane(pane) for pane in session_panes) if candidate is not None]
        if not worker_panes:
            continue
        if project_key not in agents_by_project:
            try:
                ensure_agent_mail_project(project_key)
                agents_by_project[project_key] = {
                    str(agent.get("name") or "").strip(): agent
                    for agent in list_agent_mail_agents(project_key)
                    if isinstance(agent, dict) and str(agent.get("name") or "").strip()
                }
            except (urllib.error.URLError, urllib.error.HTTPError, TimeoutError, RuntimeError):
                # Binding reconciliation must continue even if Agent Mail is being
                # upgraded, restarted, or temporarily unavailable.
                agents_by_project[project_key] = None
        project_agents = agents_by_project.get(project_key)
        changed_registry = False
        changed_bindings = False
        for worker in worker_panes:
            pane = worker.pane
            agent_name = registry_agent_name(registry, pane)
            if not agent_name and pane.bound_project_key == project_key and pane.bound_agent_name:
                agent_name = pane.bound_agent_name
            if agent_name:
                changed_registry = registry_add_agent(
                    registry, pane_title=pane.title, pane_id=pane.pane_id, agent_name=agent_name
                ) or changed_registry
                existing_binding = bindings_map.get(binding_key(project_key, agent_name))
                if not binding_matches_pane(existing_binding, pane) or str(existing_binding.get("program") or "") != worker.provider_program:
                    save_binding(
                        config,
                        project_key=project_key,
                        agent_name=agent_name,
                        pane=pane,
                        program=worker.provider_program,
                        session_id=None,
                    )
                    changed_bindings = True
                    bindings_map = load_bindings(config).get("bindings", {})
                if project_agents is not None and agent_name not in project_agents:
                    try:
                        registered = register_agent_mail_identity(
                            project_key=project_key,
                            program=worker.provider_program,
                            model=worker.model_hint,
                            agent_name=agent_name,
                            task_description=task_description_for_ntm_worker(registry.session_name, pane, worker.provider_program),
                        )
                        project_agents[agent_name] = registered
                    except (urllib.error.URLError, urllib.error.HTTPError, TimeoutError, RuntimeError):
                        agents_by_project[project_key] = None
                        project_agents = None
                continue
            if project_agents is None:
                continue
            try:
                created = create_agent_mail_identity(
                    project_key=project_key,
                    program=worker.provider_program,
                    model=worker.model_hint,
                    task_description=task_description_for_ntm_worker(registry.session_name, pane, worker.provider_program),
                )
            except (urllib.error.URLError, urllib.error.HTTPError, TimeoutError, RuntimeError):
                agents_by_project[project_key] = None
                project_agents = None
                continue
            created_name = str(created.get("name") or "").strip()
            if not created_name:
                raise RuntimeError("create_agent_identity returned an empty agent name")
            project_agents[created_name] = created
            changed_registry = registry_add_agent(
                registry, pane_title=pane.title, pane_id=pane.pane_id, agent_name=created_name
            ) or changed_registry
            save_binding(
                config,
                project_key=project_key,
                agent_name=created_name,
                pane=pane,
                program=worker.provider_program,
                session_id=None,
            )
            changed_bindings = True
            bindings_map = load_bindings(config).get("bindings", {})
        if changed_registry:
            save_ntm_registry(registry)
        if changed_bindings:
            panes[:] = list_tmux_panes()


def clear_identity(project_key: str, pane_key: str) -> pathlib.Path:
    path = canonical_identity_path(project_key, pane_key)
    ensure_parent(path)
    path.write_text("", encoding="utf-8")
    return path


def write_pane_identities(project_key: str, pane: PaneInfo, agent_name: str) -> list[pathlib.Path]:
    paths = [write_identity(project_key, pane.composite_key, agent_name)]
    if sanitize_pane_id(pane.pane_id) != sanitize_pane_id(pane.composite_key):
        paths.append(write_identity(project_key, pane.pane_id, agent_name))
    return paths


def clear_binding_identity_aliases(project_key: str, binding: dict[str, Any] | None) -> list[pathlib.Path]:
    if not isinstance(binding, dict):
        return []
    paths: list[pathlib.Path] = []
    seen: set[str] = set()
    for raw_key in (binding.get("pane_key"), binding.get("pane_id")):
        pane_key = str(raw_key or "").strip()
        if not pane_key or pane_key in seen:
            continue
        seen.add(pane_key)
        paths.append(clear_identity(project_key, pane_key))
    return paths


def set_tmux_pane_option(pane_id: str, option_name: str, value: str) -> None:
    run_command(["tmux", "set-option", "-p", "-t", pane_id, option_name, value], check=True)


def clear_binding_metadata_on_pane(pane_id: str) -> None:
    for option_name in PANE_OPTION_NAMES:
        set_tmux_pane_option(pane_id, option_name, "")


def clear_pane_session_id_metadata(pane_id: str) -> None:
    set_tmux_pane_option(pane_id, PANE_OPTION_SESSION_ID, "")


def write_binding_metadata_to_pane(
    *,
    pane: PaneInfo,
    project_key: str,
    agent_name: str,
    binding_nonce: str,
    program: str | None,
    session_id: str | None,
) -> None:
    option_values = {
        PANE_OPTION_AGENT_NAME: agent_name,
        PANE_OPTION_PROJECT_KEY: project_key,
        PANE_OPTION_PROJECT_HASH: project_hash(project_key),
        PANE_OPTION_BINDING_NONCE: binding_nonce,
        PANE_OPTION_PROGRAM: program or "",
        PANE_OPTION_SESSION_ID: session_id or "",
        PANE_OPTION_PANE_KEY: pane.composite_key,
    }
    for option_name, value in option_values.items():
        set_tmux_pane_option(pane.pane_id, option_name, value)


def make_binding_nonce(
    *,
    project_key: str,
    agent_name: str,
    pane: PaneInfo,
) -> str:
    payload = json.dumps(
        {
            "agent_name": agent_name,
            "pane_id": pane.pane_id,
            "pane_key": pane.composite_key,
            "pane_pid": pane.pid,
            "project_key": project_key,
            "updated_at": iso_utc_now(),
        },
        sort_keys=True,
    )
    return hashlib.sha1(payload.encode("utf-8")).hexdigest()[:16]


def list_identity_matches(project_key: str, agent_name: str) -> list[str]:
    project_dir = IDENTITY_ROOT / project_hash(project_key)
    if not project_dir.is_dir():
        return []
    matches: list[str] = []
    for entry in sorted(project_dir.iterdir()):
        if not entry.is_file():
            continue
        if entry.read_text(encoding="utf-8").strip() == agent_name:
            matches.append(entry.name)
    return matches


def read_identity_name(project_key: str, pane_key: str) -> str:
    path = canonical_identity_path(project_key, pane_key)
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except FileNotFoundError:
        return ""
    for line in lines:
        candidate = line.strip()
        if candidate:
            return candidate
    return ""


def delete_identity(project_key: str, pane_key: str) -> pathlib.Path:
    path = canonical_identity_path(project_key, pane_key)
    try:
        path.unlink()
    except FileNotFoundError:
        pass
    return path


def delete_binding_identity_aliases(project_key: str, binding: dict[str, Any] | None) -> list[pathlib.Path]:
    if not isinstance(binding, dict):
        return []
    paths: list[pathlib.Path] = []
    seen: set[str] = set()
    for raw_key in (binding.get("pane_key"), binding.get("pane_id")):
        pane_key = str(raw_key or "").strip()
        if not pane_key or pane_key in seen:
            continue
        seen.add(pane_key)
        paths.append(delete_identity(project_key, pane_key))
    return paths


def session_registry_search_paths(session_name: str, project_slug: str | None) -> list[pathlib.Path]:
    config_home = pathlib.Path(os.environ.get("XDG_CONFIG_HOME", str(HOME / ".config"))).expanduser()
    candidates = [
        config_home / "ntm" / "sessions",
        HOME / ".ntm" / "sessions",
    ]
    paths: list[pathlib.Path] = []
    seen: set[str] = set()
    for base in candidates:
        session_dir = base / session_name
        for candidate in (
            session_dir / "agent_registry.json",
            session_dir / str(project_slug or "") / "agent_registry.json",
        ):
            key = str(candidate)
            if key in seen:
                continue
            seen.add(key)
            paths.append(candidate)
    return paths


def load_session_registry(session_name: str, project_slug: str | None) -> dict[str, Any] | None:
    for path in session_registry_search_paths(session_name, project_slug):
        payload = read_json(path, None)
        if isinstance(payload, dict):
            return payload
    return None


def registry_agent_name_for_pane(
    pane: PaneInfo,
    *,
    project_slug: str | None,
    registry_cache: dict[str, dict[str, Any] | None],
) -> str:
    cache_key = f"{pane.session_name}|{project_slug or ''}"
    if cache_key not in registry_cache:
        registry_cache[cache_key] = load_session_registry(pane.session_name, project_slug)
    registry = registry_cache.get(cache_key)
    if not isinstance(registry, dict):
        return ""
    pane_id_map = registry.get("pane_id_map")
    if isinstance(pane_id_map, dict):
        candidate = str(pane_id_map.get(pane.pane_id) or "").strip()
        if candidate:
            return candidate
    agents = registry.get("agents")
    if isinstance(agents, dict):
        candidate = str(agents.get(pane.title) or "").strip()
        if candidate:
            return candidate
    return ""


def pane_has_live_identity_alias(pane: PaneInfo, *, project_key: str, agent_name: str) -> bool:
    identity_keys = [pane.composite_key]
    if pane.pane_id and pane.pane_id not in identity_keys:
        identity_keys.append(pane.pane_id)
    for pane_key in identity_keys:
        if read_identity_name(project_key, pane_key) == agent_name:
            return True
    return False


def profile_is_recent_for_auto_create(profile: dict[str, Any] | None) -> bool:
    if not isinstance(profile, dict):
        return False
    saw_timestamp = False
    for field_name in ("last_active_ts", "inception_ts"):
        raw_value = str(profile.get(field_name) or "").strip()
        if not raw_value:
            continue
        saw_timestamp = True
        parsed = parse_iso_timestamp(raw_value)
        if parsed is None:
            continue
        if parsed.tzinfo is None:
            parsed = parsed.replace(tzinfo=dt.timezone.utc)
        age = dt.datetime.now(dt.timezone.utc) - parsed.astimezone(dt.timezone.utc)
        return age <= dt.timedelta(seconds=AUTO_CREATE_RECENT_AGENT_SECONDS)
    return not saw_timestamp


def pane_provider_thread_id(
    pane: PaneInfo,
    *,
    program: str | None,
    env_cache: dict[int, dict[str, str]] | None = None,
    tree_cache: dict[int, list[int]] | None = None,
) -> str:
    if str(program or "").strip() != "codex-cli":
        return ""
    if pane.current_command in SHELL_COMMANDS:
        return ""
    return process_tree_env_value(
        pane.pid,
        "CODEX_THREAD_ID",
        env_cache=env_cache,
        tree_cache=tree_cache,
    )


def provider_identity_conflict_reason(
    pane: PaneInfo,
    *,
    project_key: str,
    program: str | None,
    panes: list[PaneInfo],
    env_cache: dict[int, dict[str, str]] | None = None,
    tree_cache: dict[int, list[int]] | None = None,
) -> str | None:
    thread_id = pane_provider_thread_id(
        pane,
        program=program,
        env_cache=env_cache,
        tree_cache=tree_cache,
    )
    if not thread_id:
        return None
    conflicts: list[str] = []
    for other in panes:
        if other.dead or other.pane_id == pane.pane_id:
            continue
        if not path_is_within_project(other.current_path, project_key):
            continue
        other_thread_id = pane_provider_thread_id(
            other,
            program=program,
            env_cache=env_cache,
            tree_cache=tree_cache,
        )
        if other_thread_id == thread_id:
            conflicts.append(other.composite_key)
    if not conflicts:
        return None
    conflict_label = ",".join(conflicts[:3])
    return f"shared-provider-thread:{thread_id}:{conflict_label}"


def provider_identity_issue_reason(
    pane: PaneInfo,
    *,
    project_key: str,
    program: str | None,
    panes: list[PaneInfo],
    env_cache: dict[int, dict[str, str]] | None = None,
    tree_cache: dict[int, list[int]] | None = None,
) -> str | None:
    conflict_reason = provider_identity_conflict_reason(
        pane,
        project_key=project_key,
        program=program,
        panes=panes,
        env_cache=env_cache,
        tree_cache=tree_cache,
    )
    if conflict_reason:
        return conflict_reason
    thread_id = pane_provider_thread_id(
        pane,
        program=program,
        env_cache=env_cache,
        tree_cache=tree_cache,
    )
    if not thread_id:
        return None
    return f"legacy-provider-thread-env:{thread_id}"


def binding_key(project_key: str, agent_name: str) -> str:
    return f"{project_key}|{agent_name}"


def binding_is_stale(binding: dict[str, Any] | None) -> bool:
    if not isinstance(binding, dict):
        return False
    return bool(str(binding.get("stale_at") or "").strip())


def load_bindings(config: Config) -> dict[str, Any]:
    payload = read_json(config.bindings_path, {"version": 1, "bindings": {}})
    if not isinstance(payload, dict):
        return {"version": 1, "bindings": {}}
    payload.setdefault("version", 1)
    payload.setdefault("bindings", {})
    return payload


def save_bindings(config: Config, bindings: dict[str, Any]) -> None:
    write_json_atomic(config.bindings_path, bindings)


def save_binding(
    config: Config,
    *,
    project_key: str,
    agent_name: str,
    pane: PaneInfo,
    program: str | None,
    session_id: str | None,
) -> None:
    bindings = load_bindings(config)
    bindings_map = bindings["bindings"]
    current_key = binding_key(project_key, agent_name)
    previous_binding = bindings_map.get(current_key) if isinstance(bindings_map.get(current_key), dict) else None
    binding_nonce = make_binding_nonce(project_key=project_key, agent_name=agent_name, pane=pane)
    evicted_bindings: list[dict[str, Any]] = []
    for other_key, other_binding in list(bindings_map.items()):
        if other_key == current_key or not isinstance(other_binding, dict):
            continue
        if other_binding.get("pane_id") == pane.pane_id or other_binding.get("pane_key") == pane.composite_key:
            evicted_bindings.append(other_binding)
            bindings_map.pop(other_key, None)
    for evicted in evicted_bindings:
        clear_binding_identity_aliases(project_key, evicted)
        loose_evicted_pane = resolve_bound_pane_loose(evicted, list_tmux_panes())
        if loose_evicted_pane is not None:
            clear_binding_metadata_on_pane(loose_evicted_pane.pane_id)
    old_pane = resolve_bound_pane_loose(previous_binding, list_tmux_panes())
    if old_pane is not None and (
        old_pane.pane_id != pane.pane_id or old_pane.composite_key != pane.composite_key
    ):
        clear_binding_metadata_on_pane(old_pane.pane_id)
    if previous_binding and (
        str(previous_binding.get("pane_id") or "").strip() != pane.pane_id
        or str(previous_binding.get("pane_key") or "").strip() != pane.composite_key
    ):
        clear_binding_identity_aliases(project_key, previous_binding)
    bindings_map[current_key] = {
        "project_key": project_key,
        "agent_name": agent_name,
        "pane_key": pane.composite_key,
        "sanitized_pane_key": pane.sanitized_composite_key,
        "pane_id": pane.pane_id,
        "pane_pid": pane.pid,
        "session_name": pane.session_name,
        "binding_nonce": binding_nonce,
        "program": program,
        "session_id": session_id,
        "updated_at": iso_utc_now(),
    }
    save_bindings(config, bindings)
    write_pane_identities(project_key, pane, agent_name)
    write_binding_metadata_to_pane(
        pane=pane,
        project_key=project_key,
        agent_name=agent_name,
        binding_nonce=binding_nonce,
        program=program,
        session_id=session_id,
    )


def mark_binding_stale(
    config: Config,
    *,
    project_key: str,
    agent_name: str,
    reason: str,
) -> None:
    bindings = load_bindings(config)
    entry = bindings.get("bindings", {}).get(binding_key(project_key, agent_name))
    if not isinstance(entry, dict):
        return
    entry["stale_at"] = iso_utc_now()
    entry["stale_reason"] = reason
    save_bindings(config, bindings)


def reconcile_live_binding_artifacts(config: Config, *, panes: list[PaneInfo]) -> None:
    bindings = load_bindings(config).get("bindings", {})
    if not isinstance(bindings, dict):
        return
    for binding in bindings.values():
        if not isinstance(binding, dict) or binding_is_stale(binding):
            continue
        pane = resolve_bound_pane(binding, panes)
        if pane is None or pane_is_shadow_session(config, pane):
            continue
        project_key = str(binding.get("project_key") or "").strip()
        agent_name = str(binding.get("agent_name") or "").strip()
        if not project_key or not agent_name:
            continue
        write_pane_identities(project_key, pane, agent_name)
        if not binding_metadata_matches_pane(binding, pane):
            write_binding_metadata_to_pane(
                pane=pane,
                project_key=project_key,
                agent_name=agent_name,
                binding_nonce=str(binding.get("binding_nonce") or "").strip(),
                program=str(binding.get("program") or "").strip() or None,
                session_id=str(binding.get("session_id") or "").strip() or None,
            )


def repair_conflicted_provider_panes(config: Config, *, panes: list[PaneInfo]) -> list[PaneInfo]:
    bindings = load_bindings(config).get("bindings", {})
    if not isinstance(bindings, dict):
        return panes
    env_cache: dict[int, dict[str, str]] = {}
    tree_cache: dict[int, list[int]] = {}
    repaired = False
    for binding in bindings.values():
        if not isinstance(binding, dict) or binding_is_stale(binding):
            continue
        pane = resolve_bound_pane(binding, panes)
        if pane is None or pane.dead or pane_is_shadow_session(config, pane):
            continue
        project_key = str(binding.get("project_key") or "").strip()
        agent_name = str(binding.get("agent_name") or "").strip()
        program = str(binding.get("program") or "").strip()
        if not project_key or not agent_name or program != "codex-cli":
            continue
        issue_reason = provider_identity_issue_reason(
            pane,
            project_key=project_key,
            program=program,
            panes=panes,
            env_cache=env_cache,
            tree_cache=tree_cache,
        )
        if not issue_reason:
            continue
        prompt_state, state_reason, _ = classify_pane_prompt_state_stable(pane)
        if prompt_state != "idle_prompt":
            continue
        argv = pane_launcher_argv(pane, tree_cache=tree_cache)
        if not argv:
            continue
        try:
            run_command(
                [
                    "tmux",
                    "respawn-pane",
                    "-k",
                    "-t",
                    pane.pane_id,
                    "-c",
                    pane.current_path or project_key,
                    shlex.join(argv),
                ],
                check=True,
            )
        except subprocess.CalledProcessError:
            continue
        log_event(
            config,
            {
                "timestamp": iso_utc_now(),
                "action": "auto-respawned-conflicted-provider-pane",
                "project_key": project_key,
                "agent_name": agent_name,
                "program": program,
                "pane_id": pane.pane_id,
                "pane_key": pane.composite_key,
                "pane_title": pane.title,
                "prompt_state": prompt_state,
                "state_reason": state_reason,
                "deferred_reason": issue_reason,
                "command": argv,
            },
        )
        repaired = True
        time.sleep(0.5)
    if not repaired:
        return panes
    return list_tmux_panes()


def conflicting_session_id_agents(
    bindings: dict[str, Any],
    *,
    project_key: str,
    agent_name: str,
    session_id: str | None,
) -> list[str]:
    candidate = str(session_id or "").strip()
    if not candidate:
        return []
    conflicts: set[str] = set()
    for other_binding in bindings.values():
        if not isinstance(other_binding, dict):
            continue
        if str(other_binding.get("project_key") or "").strip() != project_key:
            continue
        other_agent = str(other_binding.get("agent_name") or "").strip()
        if not other_agent or other_agent == agent_name:
            continue
        if str(other_binding.get("session_id") or "").strip() == candidate:
            conflicts.add(other_agent)
    return sorted(conflicts)


def safe_session_id_for_binding(
    bindings: dict[str, Any],
    *,
    project_key: str,
    agent_name: str,
    session_id: str | None,
) -> str | None:
    candidate = str(session_id or "").strip()
    if not candidate:
        return None
    if conflicting_session_id_agents(
        bindings,
        project_key=project_key,
        agent_name=agent_name,
        session_id=candidate,
    ):
        return None
    return candidate


def scrub_unsafe_binding_session_ids(
    config: Config,
    *,
    panes: list[PaneInfo] | None = None,
) -> dict[str, Any]:
    panes = panes if panes is not None else list_tmux_panes()
    bindings_payload = load_bindings(config)
    bindings_map = bindings_payload.get("bindings", {})
    grouped: dict[tuple[str, str], list[tuple[str, dict[str, Any]]]] = {}
    for binding_key_value, binding in bindings_map.items():
        if not isinstance(binding, dict):
            continue
        project_key = str(binding.get("project_key") or "").strip()
        session_id = str(binding.get("session_id") or "").strip()
        if not project_key or not session_id:
            continue
        grouped.setdefault((project_key, session_id), []).append((binding_key_value, binding))

    changed = False
    for (_, _session_id), entries in grouped.items():
        distinct_agents = {
            str(binding.get("agent_name") or "").strip()
            for _, binding in entries
            if str(binding.get("agent_name") or "").strip()
        }
        if len(distinct_agents) < 2:
            continue
        for _, binding in entries:
            agent_name = str(binding.get("agent_name") or "").strip()
            pane = resolve_bound_pane_loose(binding, panes)
            if str(binding.get("session_id") or "").strip():
                binding["session_id"] = None
                binding["session_id_scrubbed_at"] = iso_utc_now()
                binding["session_id_scrub_reason"] = "shared-session-id-conflict"
                changed = True
            if pane is not None:
                clear_pane_session_id_metadata(pane.pane_id)
                if pane_has_shadow_session_name(config, pane):
                    clear_binding_metadata_on_pane(pane.pane_id)
                    clear_binding_identity_aliases(str(binding.get("project_key") or "").strip(), binding)
                    binding["stale_at"] = iso_utc_now()
                    binding["stale_reason"] = "shared-session-id-shadow-binding"
                    changed = True
            elif not binding_is_stale(binding) and agent_name:
                binding["stale_at"] = iso_utc_now()
                binding["stale_reason"] = "shared-session-id-binding-missing"
                changed = True

    if changed:
        save_bindings(config, bindings_payload)
    return bindings_payload


def cleanup_shadow_sessions(config: Config, *, panes: list[PaneInfo] | None = None) -> list[PaneInfo]:
    panes = panes if panes is not None else list_tmux_panes()
    sessions_to_kill = sorted(
        {
            pane.session_name
            for pane in panes
            if pane_is_disposable_shadow_session(config, pane)
        }
    )
    for session_name in sessions_to_kill:
        subprocess.run(
            ["tmux", "kill-session", "-t", session_name],
            capture_output=True,
            text=True,
        )
        append_jsonl(
            config.log_path,
            {
                "timestamp": iso_utc_now(),
                "action": "removed-shadow-session",
                "session_name": session_name,
            },
        )
    if sessions_to_kill:
        return list_tmux_panes()
    return panes


def prune_inactive_bindings(
    config: Config,
    *,
    panes: list[PaneInfo] | None = None,
) -> dict[str, Any]:
    panes = panes if panes is not None else list_tmux_panes()
    bindings_payload = load_bindings(config)
    bindings_map = bindings_payload.get("bindings", {})
    changed = False
    for key, binding in list(bindings_map.items()):
        if not isinstance(binding, dict):
            bindings_map.pop(key, None)
            changed = True
            continue
        pane = resolve_bound_pane(binding, panes)
        if pane is not None and not pane_is_disposable_shadow_session(config, pane):
            continue
        project_key = str(binding.get("project_key") or "").strip()
        delete_binding_identity_aliases(project_key, binding)
        loose_pane = resolve_bound_pane_loose(binding, panes)
        if loose_pane is not None:
            clear_binding_metadata_on_pane(loose_pane.pane_id)
        bindings_map.pop(key, None)
        changed = True
    if changed:
        save_bindings(config, bindings_payload)
    return bindings_payload


def resolve_project_from_slug(config: Config, project_slug: str) -> dict[str, Any] | None:
    path = config.mailbox_root / "projects" / project_slug / "project.json"
    payload = read_json(path, None)
    if not isinstance(payload, dict):
