def save_state(config: Config, state: dict[str, Any]) -> None:
    write_json_atomic(config.state_path, state)


def exhaust_legacy_retry_loops(config: Config, state: dict[str, Any]) -> bool:
    signals = state.get("signals", {})
    if not isinstance(signals, dict):
        return False
    changed = False
    exhausted_at = iso_utc_now()
    for entry in signals.values():
        if not isinstance(entry, dict):
            continue
        if entry.get("delivered", True):
            continue
        if "attempt_count" in entry:
            continue
        entry["attempt_count"] = config.max_retry_attempts + 1
        entry["retry_exhausted_at"] = str(entry.get("last_attempt_at") or exhausted_at)
        changed = True
    return changed


def build_wake_token(
    *,
    agent_name: str,
    signal_payload: dict[str, Any],
) -> str:
    message = signal_payload.get("message") or {}
    message_id = message.get("id") or "unknown"
    return f"{WAKE_TOKEN_PREFIX}{agent_name}:{message_id}]"


def normalize_importance(message: dict[str, Any] | None) -> str:
    raw_value = str((message or {}).get("importance") or "").strip().lower()
    if raw_value in NORMALIZED_IMPORTANCE_VALUES:
        return raw_value
    return "normal"


def build_prompt(
    config: Config,
    *,
    agent_name: str,
    project_key: str,
    pane: PaneInfo,
    signal_payload: dict[str, Any],
) -> str:
    message = signal_payload.get("message") or {}
    prompt = config.wake_prompt_template.format(
        agent_name=agent_name,
        project_key=project_key,
        project_slug=signal_payload.get("project", ""),
        sender=message.get("from") or "unknown sender",
        subject=message.get("subject") or "new message",
        importance=normalize_importance(message),
        message_id=message.get("id") or "unknown",
        pane_id=pane.pane_id,
        pane_key=pane.composite_key,
        pane_title=pane.title,
    )
    prompt = " ".join(prompt.split())
    return f"{build_wake_token(agent_name=agent_name, signal_payload=signal_payload)} {prompt}"


def provider_spec_for_program(config: Config, program: str | None) -> ProviderSpec | None:
    if not program:
        return None
    return config.provider_specs.get(program)


def lookup_latest_session_id(
    config: Config,
    *,
    program: str | None,
    project_key: str,
) -> str | None:
    spec = provider_spec_for_program(config, program)
    if spec is None or not spec.session_lookup_provider:
        return None
    try:
        result = run_command(
            [
                "casr",
                "list",
                "--workspace",
                project_key,
                "--provider",
                spec.session_lookup_provider,
                "--limit",
                "1",
                "--sort",
                "date",
                "--json",
            ]
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    if not isinstance(payload, list) or not payload:
        return None
    session_id = payload[0].get("session_id")
    if not isinstance(session_id, str) or not session_id.strip():
        return None
    return session_id.strip()


def pane_matches_provider(pane: PaneInfo, spec: ProviderSpec | None) -> bool:
    if spec is None:
        return False
    if pane.current_command in spec.active_commands:
        return True
    return any(marker in pane.title for marker in spec.title_markers)


def binding_matches_pane_loose(binding: dict[str, Any] | None, pane: PaneInfo) -> bool:
    if not binding or binding_is_stale(binding):
        return False
    expected_pane_id = str(binding.get("pane_id") or "").strip()
    expected_pane_key = str(binding.get("pane_key") or "").strip()
    if expected_pane_id and pane.pane_id == expected_pane_id:
        return True
    if expected_pane_key and pane.composite_key == expected_pane_key:
        return True
    return False


def pane_has_agent_binding_metadata(
    pane: PaneInfo,
    *,
    project_key: str,
    agent_name: str,
) -> bool:
    if pane.bound_agent_name != agent_name:
        return False
    expected_project_hash = project_hash(project_key)
    if pane.bound_project_hash and pane.bound_project_hash != expected_project_hash:
        return False
    if pane.bound_project_key and pane.bound_project_key != project_key:
        return False
    return bool(pane.bound_project_hash or pane.bound_project_key)


def binding_metadata_matches_pane(binding: dict[str, Any], pane: PaneInfo) -> bool:
    project_key = str(binding.get("project_key") or "").strip()
    agent_name = str(binding.get("agent_name") or "").strip()
    if not project_key or not agent_name:
        return False
    if not pane_has_agent_binding_metadata(pane, project_key=project_key, agent_name=agent_name):
        return False
    expected_nonce = str(binding.get("binding_nonce") or "").strip()
    if expected_nonce and pane.bound_binding_nonce != expected_nonce:
        return False
    expected_pane_key = str(binding.get("pane_key") or "").strip()
    if expected_pane_key and pane.bound_pane_key and pane.bound_pane_key != expected_pane_key:
        return False
    expected_program = str(binding.get("program") or "").strip()
    if expected_program and pane.bound_program and pane.bound_program != expected_program:
        return False
    return True


def binding_matches_pane(binding: dict[str, Any] | None, pane: PaneInfo) -> bool:
    if not binding or binding_is_stale(binding) or not binding_matches_pane_loose(binding, pane):
        return False
    expected_pane_id = str(binding.get("pane_id") or "").strip()
    expected_pane_key = str(binding.get("pane_key") or "").strip()
    expected_pid = int(binding.get("pane_pid") or 0)
    if expected_pane_id and pane.pane_id != expected_pane_id:
        return False
    if expected_pane_key and pane.composite_key != expected_pane_key:
        return False
    if expected_pid and pane.pid != expected_pid:
        return False
    project_key = str(binding.get("project_key") or "").strip()
    if project_key and not path_is_within_project(pane.current_path, project_key):
        return False
    return binding_metadata_matches_pane(binding, pane)


def binding_claimed_by_other_agent(
    bindings: dict[str, Any],
    *,
    project_key: str,
    agent_name: str,
    pane: PaneInfo,
) -> dict[str, Any] | None:
    current_key = binding_key(project_key, agent_name)
    for other_key, other_binding in bindings.items():
        if other_key == current_key or not isinstance(other_binding, dict):
            continue
        if binding_is_stale(other_binding):
            continue
        if binding_matches_pane(other_binding, pane):
            return other_binding
    return None


def resolve_bound_pane(
    binding: dict[str, Any] | None,
    panes: list[PaneInfo],
) -> PaneInfo | None:
    if not isinstance(binding, dict) or binding_is_stale(binding):
        return None
    for pane in panes:
        if pane.dead:
            continue
        if binding_matches_pane(binding, pane):
            return pane
    return None


def resolve_bound_pane_loose(
    binding: dict[str, Any] | None,
    panes: list[PaneInfo],
) -> PaneInfo | None:
    if not isinstance(binding, dict) or binding_is_stale(binding):
        return None
    for pane in panes:
        if pane.dead:
            continue
        if binding_matches_pane_loose(binding, pane):
            return pane
    return None


def path_is_within_project(path_value: str, project_key: str) -> bool:
    try:
        path = pathlib.Path(path_value).resolve()
        project = pathlib.Path(project_key).resolve()
    except OSError:
        return False
    if path == project:
        return True
    return project in path.parents


def git_probe_cwd(path_value: str) -> pathlib.Path | None:
    try:
        path = pathlib.Path(path_value).resolve()
    except OSError:
        return None
    if path.is_dir():
        return path
    return path.parent if path.parent.exists() else None


def resolve_git_output_path(raw_value: str, *, cwd: pathlib.Path) -> pathlib.Path | None:
    candidate = raw_value.strip()
    if not candidate:
        return None
    path = pathlib.Path(candidate)
    if not path.is_absolute():
        path = (cwd / path).resolve()
    else:
        path = path.resolve()
    return path


def git_repo_root(path_value: str) -> pathlib.Path | None:
    cwd = git_probe_cwd(path_value)
    if cwd is None:
        return None
    try:
        result = run_command(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=cwd,
            timeout=2.0,
        )
    except (FileNotFoundError, subprocess.CalledProcessError, subprocess.TimeoutExpired, OSError):
        return None
    return resolve_git_output_path(result.stdout, cwd=cwd)


def git_common_dir(path_value: str) -> pathlib.Path | None:
    cwd = git_probe_cwd(path_value)
    if cwd is None:
        return None
    try:
        result = run_command(
            ["git", "rev-parse", "--path-format=absolute", "--git-common-dir"],
            cwd=cwd,
            timeout=2.0,
        )
    except (FileNotFoundError, subprocess.CalledProcessError, subprocess.TimeoutExpired, OSError):
        return None
    return resolve_git_output_path(result.stdout, cwd=cwd)


def same_git_workspace(path_a: str, path_b: str) -> bool:
    common_a = git_common_dir(path_a)
    common_b = git_common_dir(path_b)
    if common_a is None or common_b is None:
        return False
    return common_a == common_b


def find_beads_repo_root(path_value: str) -> pathlib.Path | None:
    repo_root = git_repo_root(path_value)
    if repo_root is None:
        return None
    if not (repo_root / ".beads").is_dir():
        return None
    return repo_root


def project_work_state_for_repo_root(
    repo_root: str | pathlib.Path,
    cache: dict[str, ProjectWorkState] | None = None,
) -> ProjectWorkState:
    resolved_root = pathlib.Path(repo_root).resolve()
    cache_key = str(resolved_root)
    # Cache both successful and unavailable reads so one scan/status run does not
    # repeatedly spawn `br` for the same repo root.
    if cache is not None and cache_key in cache:
        return cache[cache_key]
    if not (resolved_root / ".beads").is_dir():
        state = ProjectWorkState.unavailable(
            repo_root=resolved_root,
            source="observer-mode-br",
            error="beads-repo-not-found",
        )
    else:
        try:
            result = run_command(
                [
                    "br",
                    "--json",
                    "--no-auto-flush",
                    "--no-auto-import",
                    "--lock-timeout",
                    "250",
                    "stats",
                ],
                check=False,
                cwd=resolved_root,
                timeout=5.0,
            )
        except FileNotFoundError:
            state = ProjectWorkState.unavailable(
                repo_root=resolved_root,
                source="observer-mode-br",
                error="br-not-installed",
            )
        except subprocess.TimeoutExpired:
            state = ProjectWorkState.unavailable(
                repo_root=resolved_root,
                source="observer-mode-br",
                error="br-stats-timeout",
            )
        except OSError as exc:
            state = ProjectWorkState.unavailable(
                repo_root=resolved_root,
                source="observer-mode-br",
                error=str(exc),
            )
        else:
            try:
                payload = json.loads(result.stdout or "{}")
            except json.JSONDecodeError:
                state = ProjectWorkState.unavailable(
                    repo_root=resolved_root,
                    source="observer-mode-br",
                    error="br-stats-invalid-json",
                )
            else:
                summary = payload.get("summary") if isinstance(payload, dict) else None
                if isinstance(summary, dict):
                    state = ProjectWorkState(
                        repo_root=resolved_root,
                        source="observer-mode-br",
                        available=True,
                        open_count=max(0, parse_int(summary.get("open_issues", 0), 0)),
                        ready_count=max(0, parse_int(summary.get("ready_issues", 0), 0)),
                        in_progress_count=max(0, parse_int(summary.get("in_progress_issues", 0), 0)),
                    )
                else:
                    error_payload = payload.get("error") if isinstance(payload, dict) else None
                    if isinstance(error_payload, dict):
                        error_code = str(error_payload.get("code") or "BR_ERROR")
                        error_message = str(error_payload.get("message") or "unknown br error")
                        error_text = f"{error_code}: {error_message}"
                    elif result.returncode != 0 and result.stderr.strip():
                        error_text = result.stderr.strip()
                    else:
                        error_text = "br-stats-missing-summary"
                    state = ProjectWorkState.unavailable(
                        repo_root=resolved_root,
                        source="observer-mode-br",
                        error=error_text,
                    )
    if cache is not None:
        cache[cache_key] = state
    return state


def project_work_state_for_target(
    pane: PaneInfo | None,
    project_key: str,
    cache: dict[str, ProjectWorkState] | None = None,
) -> ProjectWorkState:
    if pane is not None and pane.current_path and same_git_workspace(pane.current_path, project_key):
        pane_repo_root = find_beads_repo_root(pane.current_path)
        if pane_repo_root is not None:
            return project_work_state_for_repo_root(pane_repo_root, cache).with_source("pane-worktree")
    canonical_repo_root = find_beads_repo_root(project_key)
    if canonical_repo_root is not None:
        return project_work_state_for_repo_root(canonical_repo_root, cache).with_source("canonical-project")
    return ProjectWorkState.unavailable(
        repo_root=git_repo_root(project_key),
        source="canonical-project",
        error="beads-repo-not-found",
    )


def beads_gate_decision(importance: str, work_state: ProjectWorkState) -> tuple[str, str | None]:
    normalized_importance = normalize_importance({"importance": importance})
    if not work_state.available:
        return POLICY_DECISION_SKIP_UNAVAILABLE, "work-state-unavailable"
    open_count = work_state.open_count or 0
    ready_count = work_state.ready_count or 0
    if open_count == 0:
        if normalized_importance == "urgent":
            return POLICY_DECISION_WAKE, None
        return POLICY_DECISION_SUPPRESS_NO_OPEN, "no-open-beads"
    if ready_count == 0:
        if normalized_importance in {"high", "urgent"}:
            return POLICY_DECISION_WAKE, None
        return POLICY_DECISION_SUPPRESS_NO_READY, "no-ready-beads"
    return POLICY_DECISION_WAKE, None


def beads_gate_status_explanation(
    config: "Config", work_state: ProjectWorkState
) -> str:
    if not config.beads_gate_enabled:
        return "policy disabled — pre-v2 wake behavior preserved"
    if not work_state.available:
        error = work_state.error or "unknown"
        return (
            f"work state unavailable ({error}) — failing open, all wakes proceed"
        )
    open_count = work_state.open_count or 0
    ready_count = work_state.ready_count or 0
    decision_normal, _ = beads_gate_decision("normal", work_state)
    if decision_normal == POLICY_DECISION_SUPPRESS_NO_OPEN:
        return "no open beads — only urgent wakes will land"
    if decision_normal == POLICY_DECISION_SUPPRESS_NO_READY:
        return (
            f"open but no ready beads ({open_count} open) — "
            "only high and urgent wakes will land"
        )
    return f"{open_count} open, {ready_count} ready — all wakes proceed normally"


def work_state_event_fields(work_state: ProjectWorkState | None) -> dict[str, Any]:
    if work_state is None:
        return {
            "work_state_repo_root": None,
            "work_state_source": None,
            "work_state_available": None,
            "work_state_open_count": None,
            "work_state_ready_count": None,
            "work_state_in_progress_count": None,
            "work_state_error": None,
        }
    return {
        "work_state_repo_root": str(work_state.repo_root) if work_state.repo_root is not None else None,
        "work_state_source": work_state.source,
        "work_state_available": work_state.available,
        "work_state_open_count": work_state.open_count,
        "work_state_ready_count": work_state.ready_count,
        "work_state_in_progress_count": work_state.in_progress_count,
        "work_state_error": work_state.error,
    }


def pane_has_shadow_session_name(config: Config, pane: PaneInfo) -> bool:
    return pane.session_name.startswith(f"{config.create_session_prefix}-")


def pane_has_binding_metadata(pane: PaneInfo) -> bool:
    if not pane.bound_agent_name:
        return False
    return bool(
        pane.bound_project_key
        or pane.bound_project_hash
        or pane.bound_binding_nonce
        or pane.bound_program
        or pane.bound_pane_key
    )


def pane_is_shadow_session(config: Config, pane: PaneInfo) -> bool:
    # Watcher-created shadow sessions start as shell panes. Once a provider is
    # actually running in that pane, it is no longer shadow bootstrap state.
    return (
        pane_has_shadow_session_name(config, pane)
        and pane.current_command in SHELL_COMMANDS
    )


def pane_is_disposable_shadow_session(config: Config, pane: PaneInfo) -> bool:
    if not pane_is_shadow_session(config, pane):
        return False
    # Bound bootstrap panes are real ownership claims and must survive across
    # scans so newly spawned agents keep an owned pane immediately.
    return not pane_has_binding_metadata(pane)


def native_project_provider_panes(
    config: Config,
    *,
    panes: list[PaneInfo],
    project_key: str,
    spec: ProviderSpec | None,
    bindings: dict[str, Any],
    agent_name: str,
) -> list[PaneInfo]:
    candidates: list[PaneInfo] = []
    for pane in panes:
        if pane.dead:
            continue
        if pane_is_shadow_session(config, pane):
            continue
        if not path_is_within_project(pane.current_path, project_key):
            continue
        if not pane_matches_provider(pane, spec):
            continue
        if binding_claimed_by_other_agent(
            bindings,
            project_key=project_key,
            agent_name=agent_name,
            pane=pane,
        ):
            continue
        candidates.append(pane)
    return candidates


def pane_is_live_provider(
    pane: PaneInfo,
    *,
    spec: ProviderSpec | None,
    binding: dict[str, Any] | None,
) -> bool:
    if pane_matches_provider(pane, spec):
        return True
    return binding_matches_pane(binding, pane) and pane.current_command not in SHELL_COMMANDS


def capture_pane_text(
    pane_id: str,
    *,
    scrollback_lines: int = 120,
    visible_only: bool = False,
) -> str:
    try:
        args = ["tmux", "capture-pane", "-p", "-t", pane_id]
        if not visible_only:
            args[3:3] = ["-S", f"-{scrollback_lines}"]
        return run_command(args).stdout
    except subprocess.CalledProcessError:
        return ""


def classify_pane_prompt_state(pane: PaneInfo) -> tuple[str, str]:
    capture = capture_pane_text(pane.pane_id, visible_only=True)
    trimmed_lines = [line.rstrip() for line in capture.splitlines() if line.strip()]
    tail_lines = trimmed_lines[-12:]

    latest_working: tuple[int, str] | None = None
    latest_awaiting: tuple[int, str] | None = None
    latest_prompt_index = -1
    for index, line in enumerate(tail_lines):
        lowered = line.lower()
        if line.lstrip().startswith(("›", ">")):
            latest_prompt_index = index
        for marker in BUSY_CAPTURE_MARKERS:
            if marker in lowered:
                latest_working = (index, marker)
        for marker in AWAITING_INPUT_MARKERS:
            if marker in lowered:
                latest_awaiting = (index, marker)

    if latest_awaiting and latest_working:
        if latest_awaiting[0] >= latest_working[0]:
            return "awaiting_input", f"awaiting_input:{latest_awaiting[1]}"
        return "working", f"working:{latest_working[1]}"
    if latest_awaiting:
        return "awaiting_input", f"awaiting_input:{latest_awaiting[1]}"
    if latest_working:
        return "working", f"working:{latest_working[1]}"
    if latest_prompt_index != -1:
        return "idle_prompt", "prompt-marker"
    if pane.current_command not in SHELL_COMMANDS:
        return "idle_prompt", "non-shell-no-working-marker"
    return "shell", "shell-pane"


def classify_pane_prompt_state_stable(
    pane: PaneInfo,
    *,
    samples: int = 4,
    sample_interval_seconds: float = 0.35,
) -> tuple[str, str, list[dict[str, str]]]:
    observed: list[dict[str, str]] = []
    counts: dict[str, int] = {}
    latest_reason_by_state: dict[str, str] = {}
    for index in range(samples):
        state, reason = classify_pane_prompt_state(pane)
        observed.append({"state": state, "reason": reason})
        counts[state] = counts.get(state, 0) + 1
        latest_reason_by_state[state] = reason
        if index + 1 < samples:
            time.sleep(sample_interval_seconds)

    for preferred_state in ("working", "awaiting_input", "idle_prompt", "shell"):
        if counts.get(preferred_state):
            return preferred_state, latest_reason_by_state[preferred_state], observed
    return "shell", "shell-pane", observed


def retry_is_due(previous: dict[str, Any], *, config: Config) -> bool:
    if previous.get("delivered", True):
        return False
    if previous.get("retry_exhausted_at"):
        return False
    if parse_int(previous.get("attempt_count"), 0) > config.max_retry_attempts:
        return False
    last_attempt = parse_iso_timestamp(str(previous.get("last_attempt_at") or ""))
    if last_attempt is None:
        return True
    now = dt.datetime.now(dt.timezone.utc)
    return (now - last_attempt).total_seconds() >= config.deferred_retry_seconds


def build_launch_command(
    *,
    spec: ProviderSpec | None,
    project_key: str,
    prompt: str,
    session_id: str | None,
) -> str:
    substitutions = {
        "project_key": project_key,
        "project_key_quoted": shell_quote(project_key),
        "prompt": prompt,
        "prompt_quoted": shell_quote(prompt),
        "session_id": session_id or "",
        "session_id_quoted": shell_quote(session_id or ""),
    }
    if spec is None:
        return f"cd {shell_quote(project_key)} && printf '%s\\n' {shell_quote(prompt)}"
    if session_id and spec.resume_template:
        return spec.resume_template.format(**substitutions)
    return spec.launch_template.format(**substitutions)


def should_auto_create_pane(
    config: Config,
    *,
    selection_source: str | None,
    program: str | None,
    profile: dict[str, Any] | None,
) -> bool:
    if not config.auto_create_missing_panes:
        return False
    if selection_source is not None:
        return False
    if provider_spec_for_program(config, program) is None:
        return False
    return profile_is_recent_for_auto_create(profile)


def send_prompt_to_pane(pane_id: str, prompt: str) -> None:
    run_command(["tmux", "send-keys", "-t", pane_id, "-l", prompt], check=True)
    time.sleep(0.1)
    run_command(["tmux", "send-keys", "-t", pane_id, "C-m"], check=True)


def send_command_to_pane(pane_id: str, command: str) -> None:
    run_command(["tmux", "send-keys", "-t", pane_id, "-l", command], check=True)
    time.sleep(0.1)
    run_command(["tmux", "send-keys", "-t", pane_id, "C-m"], check=True)


def wait_for_capture_change(
    pane_id: str,
    before: str,
    *,
    timeout_seconds: float = 1.5,
) -> tuple[bool, str]:
    deadline = time.monotonic() + timeout_seconds
    latest = before
    while time.monotonic() < deadline:
        latest = capture_pane_text(pane_id, visible_only=True)
        if latest != before:
            return True, latest
        time.sleep(0.05)
    return False, latest


def extract_wake_token(prompt: str) -> str | None:
    stripped = prompt.lstrip()
    if not stripped.startswith(WAKE_TOKEN_PREFIX):
        return None
    closing = stripped.find("]")
    if closing == -1:
        return None
    return stripped[: closing + 1]


def prompt_visible_in_capture(prompt: str, capture: str) -> bool:
    prompt_norm = normalize_whitespace(prompt)
    capture_norm = normalize_whitespace(capture)
    if not prompt_norm or not capture_norm:
        return False
    token = extract_wake_token(prompt)
    if token:
        return normalize_whitespace(token) in capture_norm
    if prompt_norm in capture_norm:
        return True
    prompt_prefix = prompt_norm[:96].strip()
    return bool(prompt_prefix) and prompt_prefix in capture_norm


def wait_for_prompt_visibility(
    pane_id: str,
    prompt: str,
    *,
    timeout_seconds: float = 2.0,
    poll_interval_seconds: float = 0.05,
) -> tuple[bool, str]:
    deadline = time.monotonic() + timeout_seconds
    latest = capture_pane_text(pane_id, visible_only=True)
    while time.monotonic() < deadline:
        latest = capture_pane_text(pane_id, visible_only=True)
        if prompt_visible_in_capture(prompt, latest):
            return True, latest
        time.sleep(poll_interval_seconds)
    return prompt_visible_in_capture(prompt, latest), latest


def wait_for_non_idle_transition(
    pane: PaneInfo,
    *,
    timeout_seconds: float = 10.0,
    poll_interval_seconds: float = 0.5,
) -> tuple[bool, str, str, list[dict[str, str]]]:
    deadline = time.monotonic() + timeout_seconds
    observed: list[dict[str, str]] = []
    while time.monotonic() < deadline:
        state, reason = classify_pane_prompt_state(pane)
        observed.append({"state": state, "reason": reason})
        if state != "idle_prompt":
            return True, state, reason, observed
        time.sleep(poll_interval_seconds)
    final_state, final_reason = classify_pane_prompt_state(pane)
    observed.append({"state": final_state, "reason": final_reason})
    return False, final_state, final_reason, observed


def deliver_prompt_to_live_pane(
    pane: PaneInfo,
    *,
    prompt: str,
    prompt_state: str,
) -> tuple[bool, str, dict[str, Any]]:
    verification: dict[str, Any] = {"initial_prompt_state": prompt_state}
    before = capture_pane_text(pane.pane_id, visible_only=True)
    if prompt_visible_in_capture(prompt, before):
        verification["prompt_already_visible"] = True
        verification["capture_changed_after_prompt"] = False
        verification["capture_delta_chars"] = 0
        verification["prompt_visible_after_prompt"] = True
        verification["prompt_visibility_capture_delta_chars"] = 0
        verification["non_idle_transition_observed"] = None
        verification["post_send_states"] = []
        verification["final_post_send_state"] = prompt_state
        verification["final_post_send_reason"] = "prompt-already-visible"
        return True, "prompt-already-visible-in-pane", verification
    send_prompt_to_pane(pane.pane_id, prompt)
    changed, after = wait_for_capture_change(pane.pane_id, before, timeout_seconds=4.0)
    verification["capture_changed_after_prompt"] = changed
    verification["capture_delta_chars"] = abs(len(after) - len(before))
    prompt_visible, visible_capture = wait_for_prompt_visibility(
        pane.pane_id,
        prompt,
        timeout_seconds=4.0,
        poll_interval_seconds=0.05,
    )
    verification["prompt_visible_after_prompt"] = prompt_visible
    verification["prompt_visibility_capture_delta_chars"] = abs(len(visible_capture) - len(before))
    transitioned, transition_state, transition_reason, observed_states = wait_for_non_idle_transition(
        pane,
        timeout_seconds=10.0,
        poll_interval_seconds=0.5,
    )
    verification["non_idle_transition_observed"] = transitioned
    verification["post_send_states"] = observed_states
    verification["final_post_send_state"] = transition_state
    verification["final_post_send_reason"] = transition_reason
    if changed and prompt_visible:
        return True, "prompt-visible-in-pane", verification
    # Some providers consume the wake prompt immediately, redraw the pane, and move
    # straight into a non-idle state. Treat that transition as a successful wake even
    # if the literal prompt text is no longer visible in the pane capture.
    if changed and transitioned and transition_state in PROMPT_CONSUMPTION_STATES:
        return True, "prompt-consumed-by-live-provider", verification
    if not prompt_visible:
        return False, "prompt-not-visible-in-pane-after-send", verification
    if not changed:
        return False, "no-visible-pane-change-after-prompt", verification
    if transitioned:
        return True, "capture-changed-and-state-transitioned", verification
    return False, "idle-pane-did-not-leave-idle-after-prompt", verification


def make_session_name(prefix: str, project_key: str, agent_name: str) -> str:
    base = pathlib.Path(project_key).name.replace(" ", "_")
    raw = f"{prefix}-{base}-{agent_name}".lower()
    allowed = []
    for char in raw:
        if char.isalnum() or char in "-_":
            allowed.append(char)
        else:
            allowed.append("-")
    return "".join(allowed)[:48].strip("-") or "agentmail-wake"


def tmux_pane_by_id(pane_id: str) -> PaneInfo | None:
    for pane in list_tmux_panes():
        if pane.pane_id == pane_id:
            return pane
    return None


def create_tmux_pane(config: Config, project_key: str, agent_name: str) -> PaneInfo:
    session_name = make_session_name(config.create_session_prefix, project_key, agent_name)
    shell_command = config.shell_command
    has_session = subprocess.run(
        ["tmux", "has-session", "-t", session_name],
        capture_output=True,
        text=True,
    ).returncode == 0
    if has_session:
        result = run_command(
            [
                "tmux",
                "new-window",
                "-d",
                "-t",
                session_name,
                "-n",
                "wake",
                "-c",
                project_key,
                "-P",
                "-F",
                "#{pane_id}",
                shell_command,
            ]
        )
    else:
        result = run_command(
            [
                "tmux",
                "new-session",
                "-d",
                "-s",
                session_name,
                "-n",
                "wake",
                "-c",
                project_key,
                "-P",
                "-F",
                "#{pane_id}",
                shell_command,
            ]
        )
    pane_id = result.stdout.strip().splitlines()[-1].strip()
    pane = tmux_pane_by_id(pane_id)
    if pane is not None and not pane.dead:
        return pane
    raise RuntimeError(f"failed to create tmux pane for {agent_name} in {project_key}")


def select_candidate_pane(
    config: Config,
    *,
    project_key: str,
    project_slug: str | None,
    agent_name: str,
    program: str | None,
    panes: list[PaneInfo] | None = None,
) -> tuple[PaneInfo | None, bool, str | None]:
    panes = panes if panes is not None else list_tmux_panes()
    spec = provider_spec_for_program(config, program)
    bindings = load_bindings(config).get("bindings", {})
    binding = bindings.get(binding_key(project_key, agent_name))
    registry_cache: dict[str, dict[str, Any] | None] = {}
    native_candidates = native_project_provider_panes(
        config,
        panes=panes,
        project_key=project_key,
        spec=spec,
        bindings=bindings,
        agent_name=agent_name,
    )

    if isinstance(binding, dict):
        pane = resolve_bound_pane(binding, panes)
        if pane is not None:
            # Explicit bindings are the primary routing contract. Unrelated native
            # provider panes in the same project must not override a live binding;
            # busy suppression still happens later during delivery.
            return pane, pane_is_live_provider(pane, spec=spec, binding=binding), "binding"

    owned_candidates: list[tuple[int, PaneInfo]] = []
    for pane in panes:
        if pane.dead:
            continue
        if pane_is_disposable_shadow_session(config, pane):
            continue
        if not path_is_within_project(pane.current_path, project_key):
            continue
        if binding_claimed_by_other_agent(
            bindings,
            project_key=project_key,
            agent_name=agent_name,
            pane=pane,
        ):
            continue
        ownership_score = 0
        if pane_has_agent_binding_metadata(pane, project_key=project_key, agent_name=agent_name):
            ownership_score += 100
        registry_agent = registry_agent_name_for_pane(
            pane,
            project_slug=project_slug,
            registry_cache=registry_cache,
        )
        if registry_agent == agent_name:
            ownership_score += 90
        if pane_has_live_identity_alias(pane, project_key=project_key, agent_name=agent_name):
            ownership_score += 80
        if ownership_score == 0:
            continue
        score = ownership_score
        if pane_matches_provider(pane, spec):
            score += 50
        if pane.active:
            score += 10
        if pane.current_command not in SHELL_COMMANDS:
            score += 5
        owned_candidates.append((score, pane))

    if not owned_candidates:
        if native_candidates:
            return None, False, "unbound-native-provider-pane"
        return None, False, None
    owned_candidates.sort(key=lambda item: (-item[0], item[1].composite_key))
    top_score = owned_candidates[0][0]
    winners = [pane for score, pane in owned_candidates if score == top_score]
    if len(winners) != 1:
        return None, False, "ambiguous-owned-pane"
    winner = winners[0]
    return winner, pane_is_live_provider(winner, spec=spec, binding=binding), "pane-metadata"


def process_signal(
    config: Config,
    *,
    signal_path: pathlib.Path,
    signal_payload: dict[str, Any],
    work_state_cache: dict[str, ProjectWorkState] | None = None,
) -> dict[str, Any]:
    project_slug = str(signal_payload.get("project") or "")
    agent_name = str(signal_payload.get("agent") or "")
    if not project_slug or not agent_name:
        raise RuntimeError(f"signal missing project/agent fields: {signal_path}")

    project_meta = resolve_project_from_slug(config, project_slug)
    if not project_meta:
        raise RuntimeError(f"project slug {project_slug!r} not found under mailbox root")
    project_key = str(project_meta.get("human_key") or "")
    if not project_key:
        raise RuntimeError(f"project slug {project_slug!r} has no human_key")

    profile = resolve_agent_profile(config, project_slug=project_slug, agent_name=agent_name)
    program = str(profile.get("program") or "")
    panes = list_tmux_panes()
    session_id = None
    session_id_source = None
    bindings = scrub_unsafe_binding_session_ids(config, panes=panes).get("bindings", {})
    binding = bindings.get(binding_key(project_key, agent_name))
    stale_binding_reason = None
    if binding:
        session_id = safe_session_id_for_binding(
            bindings,
            project_key=project_key,
            agent_name=agent_name,
            session_id=binding.get("session_id"),
        )
        if session_id:
            session_id_source = "binding"
        strict_pane = resolve_bound_pane(binding, panes)
        if strict_pane is None:
            stale_binding_reason = "bound-pane-missing-or-dead"
            if resolve_bound_pane_loose(binding, panes) is not None:
                stale_binding_reason = "bound-pane-proof-mismatch"
            mark_binding_stale(
                config,
                project_key=project_key,
                agent_name=agent_name,
                reason=stale_binding_reason,
            )

    pane, live_provider, selection_source = select_candidate_pane(
        config,
        project_key=project_key,
        project_slug=project_slug,
        agent_name=agent_name,
        program=program,
        panes=panes,
    )
    env_cache: dict[int, dict[str, str]] = {}
    tree_cache: dict[int, list[int]] = {}
    provider_identity_issue = None
    if pane is not None and live_provider:
        provider_identity_issue = provider_identity_issue_reason(
            pane,
            project_key=project_key,
            program=program,
            panes=panes,
            env_cache=env_cache,
            tree_cache=tree_cache,
        )
    message = signal_payload.get("message") or {}
    message_importance = normalize_importance(message)
    beads_gate_enabled = config.beads_gate_enabled
    if beads_gate_enabled:
        work_state = project_work_state_for_target(pane, project_key, cache=work_state_cache)
        beads_gate_action, beads_gate_reason = beads_gate_decision(message_importance, work_state)
    else:
        work_state = None
        beads_gate_action, beads_gate_reason = (
            POLICY_DECISION_SKIP_DISABLED,
            "feature-flag-disabled",
        )
    event_work_state = work_state_event_fields(work_state)
    created_new_pane = False
    if beads_gate_action in {
        POLICY_DECISION_SUPPRESS_NO_OPEN,
        POLICY_DECISION_SUPPRESS_NO_READY,
    }:
        event = {
            "timestamp": iso_utc_now(),
            "action": beads_gate_action,
            "created_new_pane": False,
            "selection_source": selection_source,
            "project_slug": project_slug,
            "project_key": project_key,
            "agent_name": agent_name,
            "program": program,
            "session_id": session_id,
            "session_id_source": session_id_source,
            "pane_key": pane.composite_key if pane is not None else None,
            "pane_id": pane.pane_id if pane is not None else None,
            "pane_command": pane.current_command if pane is not None else None,
            "pane_title": pane.title if pane is not None else None,
            "message": message,
            "signal_path": str(signal_path),
            "delivered": True,
            "deferred_reason": beads_gate_reason,
            "prompt_state": None,
            "state_reason": None,
            "state_samples": None,
            "delivery_verification": None,
            "binding_stale_reason": stale_binding_reason,
            "ownership_conflict_reason": provider_identity_issue,
            "provider_identity_issue_reason": provider_identity_issue,
            "message_importance": message_importance,
            "beads_gate_enabled": beads_gate_enabled,
            "beads_gate_decision": beads_gate_action,
            "beads_gate_reason": beads_gate_reason,
            **event_work_state,
        }
        log_event(config, event)
        return event
    if pane is None:
        if should_auto_create_pane(
            config,
            selection_source=selection_source,
            program=program,
            profile=profile,
        ):
            pane = create_tmux_pane(config, project_key, agent_name)
            created_new_pane = True
            panes = list_tmux_panes()
            live_provider = False
            selection_source = "created-pane"
        else:
            deferred_reason = selection_source or "no-owned-pane"
            event = {
                "timestamp": iso_utc_now(),
                "action": "deferred-no-owned-pane",
                "created_new_pane": False,
                "selection_source": selection_source,
                "project_slug": project_slug,
                "project_key": project_key,
                "agent_name": agent_name,
                "program": program,
                "session_id": session_id,
                "session_id_source": session_id_source,
                "pane_key": None,
                "pane_id": None,
                "pane_command": None,
                "pane_title": None,
                "message": message,
                "signal_path": str(signal_path),
                "delivered": False,
                "deferred_reason": deferred_reason,
                "prompt_state": None,
                "state_reason": None,
                "state_samples": None,
                "delivery_verification": None,
                "binding_stale_reason": stale_binding_reason,
                "ownership_conflict_reason": provider_identity_issue,
                "provider_identity_issue_reason": provider_identity_issue,
                "message_importance": message_importance,
                "beads_gate_enabled": beads_gate_enabled,
                "beads_gate_decision": beads_gate_action,
                "beads_gate_reason": beads_gate_reason,
                **event_work_state,
            }
            log_event(config, event)
            return event

    prompt = build_prompt(
        config,
        agent_name=agent_name,
        project_key=project_key,
        pane=pane,
        signal_payload=signal_payload,
    )

    delivered = True
    deferred_reason = None
    prompt_state = None
    state_reason = None
    state_samples: list[dict[str, str]] | None = None
    delivery_verification: dict[str, Any] | None = None
    if provider_identity_issue:
        action = (
            "deferred-ambiguous-provider-pane"
            if provider_identity_issue.startswith("shared-provider-thread:")
            else "deferred-provider-identity-issue"
        )
        delivered = False
        deferred_reason = provider_identity_issue
        prompt_state = "ambiguous_provider"
        state_reason = provider_identity_issue
    elif live_provider:
        prompt_state, state_reason, state_samples = classify_pane_prompt_state_stable(pane)
        if prompt_state in {"idle_prompt", "awaiting_input"}:
            delivered, verification_reason, delivery_verification = deliver_prompt_to_live_pane(
                pane,
                prompt=prompt,
                prompt_state=prompt_state,
            )
            if delivered:
                action = "prompted-live-pane"
            else:
                action = f"deferred-{prompt_state.replace('_', '-')}-pane"
                deferred_reason = verification_reason
        elif prompt_state == "working":
            action = "suppressed-working-pane"
            delivered = True
            deferred_reason = state_reason
        else:
            action = f"deferred-{prompt_state.replace('_', '-')}-pane"
            delivered = False
            deferred_reason = state_reason
    else:
        save_binding(
            config,
            project_key=project_key,
            agent_name=agent_name,
            pane=pane,
            program=program or None,
            session_id=session_id,
        )
        command = build_launch_command(
            spec=provider_spec_for_program(config, program),
            project_key=project_key,
            prompt=prompt,
            session_id=session_id,
        )
        send_command_to_pane(pane.pane_id, command)
        action = "launched-or-resumed-shell-pane"
    if live_provider:
        save_binding(
            config,
            project_key=project_key,
            agent_name=agent_name,
            pane=pane,
            program=program or None,
            session_id=session_id,
        )
    event = {
        "timestamp": iso_utc_now(),
        "action": action,
        "created_new_pane": created_new_pane,
        "selection_source": selection_source,
        "project_slug": project_slug,
        "project_key": project_key,
        "agent_name": agent_name,
        "program": program,
        "session_id": session_id,
        "session_id_source": session_id_source,
        "pane_key": pane.composite_key,
        "pane_id": pane.pane_id,
        "pane_command": pane.current_command,
        "pane_title": pane.title,
        "message": message,
        "signal_path": str(signal_path),
        "delivered": delivered,
        "deferred_reason": deferred_reason,
        "prompt_state": prompt_state,
        "state_reason": state_reason,
        "state_samples": state_samples,
        "delivery_verification": delivery_verification,
        "binding_stale_reason": stale_binding_reason,
        "ownership_conflict_reason": provider_identity_issue,
        "provider_identity_issue_reason": provider_identity_issue,
        "message_importance": message_importance,
        "beads_gate_enabled": beads_gate_enabled,
        "beads_gate_decision": beads_gate_action,
        "beads_gate_reason": beads_gate_reason,
        **event_work_state,
    }
    log_event(config, event)
    return event


def iter_signal_paths(config: Config) -> list[pathlib.Path]:
    agents_root = config.signals_dir / "projects"
    if not agents_root.exists():
        return []
    return sorted(agents_root.glob("*/agents/*.signal"))


def signal_signature(signal_path: pathlib.Path, signal_payload: dict[str, Any]) -> str:
    message = signal_payload.get("message") or {}
    message_id = message.get("id")
    if message_id is not None:
        return f"message:{message_id}"
    stat = signal_path.stat()
    return f"mtime:{stat.st_mtime_ns}"


def scan_once(config: Config) -> list[dict[str, Any]]:
    with acquire_scan_lock(config, blocking=False):
        ensure_agent_mail_service_available(config)
        scrub_tmux_global_environment()
        state = load_state(config)
        exhaust_legacy_retry_loops(config, state)
        panes = cleanup_shadow_sessions(config)
        scrub_unsafe_binding_session_ids(config, panes=panes)
        prune_inactive_bindings(config, panes=panes)
        reconcile_ntm_agent_mail(config, panes=panes)
        panes = list_tmux_panes()
        reconcile_live_binding_artifacts(config, panes=panes)
        panes = repair_conflicted_provider_panes(config, panes=panes)
        reconcile_ntm_agent_mail(config, panes=panes)
        panes = list_tmux_panes()
        reconcile_live_binding_artifacts(config, panes=panes)
        signals_state = state.setdefault("signals", {})
        current_paths = {str(path) for path in iter_signal_paths(config)}
        for stale_path in list(signals_state):
            if stale_path not in current_paths:
                signals_state.pop(stale_path, None)

        events: list[dict[str, Any]] = []
        work_state_cache: dict[str, ProjectWorkState] = {}
        for signal_path in iter_signal_paths(config):
            path_key = str(signal_path)
            previous = signals_state.get(path_key, {})
            try:
                raw_text = signal_path.read_text(encoding="utf-8")
            except FileNotFoundError:
                signals_state.pop(path_key, None)
                continue
            try:
                signal_payload = json.loads(raw_text)
            except json.JSONDecodeError as exc:
                try:
                    signature = f"invalid-json:{signal_path.stat().st_mtime_ns}"
                except FileNotFoundError:
                    signals_state.pop(path_key, None)
                    continue
                if previous.get("signature") == signature:
                    continue
                event = {
                    "timestamp": iso_utc_now(),
                    "action": "invalid-signal-json",
                    "signal_path": path_key,
                    "error": str(exc),
                }
                log_event(config, event)
                events.append(event)
                signals_state[path_key] = {
                    "signature": signature,
                    "processed_at": iso_utc_now(),
                    "delivered": False,
                    "last_attempt_at": iso_utc_now(),
                    "attempt_count": 1,
                }
                continue

            try:
                signature = signal_signature(signal_path, signal_payload)
            except FileNotFoundError:
                signals_state.pop(path_key, None)
                continue
            same_signature = previous.get("signature") == signature
            if same_signature and previous.get("delivered", True):
                continue
            if same_signature and not retry_is_due(previous, config=config):
                continue
            try:
                event = process_signal(
                    config,
                    signal_path=signal_path,
                    signal_payload=signal_payload,
                    work_state_cache=work_state_cache,
                )
            except Exception as exc:  # pragma: no cover - integration failure path
                event = {
                    "timestamp": iso_utc_now(),
                    "action": "wake-failed",
                    "signal_path": str(signal_path),
                    "error": str(exc),
                    "delivered": False,
                }
                log_event(config, event)
            events.append(event)
            delivered = event.get("delivered")
            attempt_count = parse_int(previous.get("attempt_count"), 0) + 1 if same_signature else 1
            state_entry = {
                "signature": signature,
                "delivered": bool(delivered) if delivered is not None else False,
                "last_attempt_at": iso_utc_now(),
                "attempt_count": attempt_count,
            }
            if state_entry["delivered"]:
                state_entry["processed_at"] = iso_utc_now()
            else:
                state_entry["queued_at"] = previous.get("queued_at") if same_signature else iso_utc_now()
                state_entry["deferred_reason"] = event.get("deferred_reason")
                if attempt_count > config.max_retry_attempts:
                    state_entry["retry_exhausted_at"] = iso_utc_now()
            signals_state[path_key] = state_entry

        save_state(config, state)
        return events


def command_watch(config: Config) -> int:
    while True:
        try:
            scan_once(config)
        except RuntimeError as exc:
            if "watcher lock is already held" not in str(exc):
                raise
        time.sleep(config.poll_interval_seconds)


def current_tmux_pane() -> PaneInfo | None:
    pane_id = os.environ.get("TMUX_PANE", "").strip()
    if not pane_id:
        return None
    for pane in list_tmux_panes():
        if pane.pane_id == pane_id:
            return pane
    return None


def cli_target_pane(args: argparse.Namespace, *, command_name: str) -> PaneInfo:
    if getattr(args, "pane", None):
        for candidate in list_tmux_panes():
            if candidate.pane_id == args.pane or candidate.composite_key == args.pane:
                return candidate
        raise SystemExit(f"pane {args.pane!r} was not found in tmux")
    pane = current_tmux_pane()
    if pane is None:
        raise SystemExit(f"{command_name} requires --pane when not running inside tmux")
    return pane


def existing_binding_for_pane(config: Config, pane: PaneInfo) -> dict[str, Any] | None:
    bindings = load_bindings(config).get("bindings", {})
    if not isinstance(bindings, dict):
        return None
    for binding in bindings.values():
        if not isinstance(binding, dict) or binding_is_stale(binding):
            continue
        if binding_matches_pane_loose(binding, pane):
            return binding
    return None


def ntm_context_for_pane(pane: PaneInfo) -> tuple[str, NTMRegistry, NTMWorkerPane] | None:
    worker = parse_ntm_worker_pane(pane)
    if worker is None:
        return None
    for _coordinator_name, project_key, registry in load_ntm_session_contexts():
        if pane.session_name != registry.session_name:
            continue
        if not path_is_within_project(pane.current_path, project_key):
            continue
        return project_key, registry, worker
    return None


def resolve_assignment_for_pane(
    config: Config,
    pane: PaneInfo,
    *,
    explicit_project_key: str | None = None,
    explicit_agent_name: str | None = None,
    explicit_program: str | None = None,
) -> dict[str, Any]:
    existing_binding = existing_binding_for_pane(config, pane)
    context = ntm_context_for_pane(pane)

    registry_project_key = ""
    registry_agent_name_value = ""
    registry_session_name = ""
    worker_program = ""
    worker_model = ""
    if context is not None:
        registry_project_key, registry, worker = context
        registry_agent_name_value = registry_agent_name(registry, pane)
        registry_session_name = registry.session_name
        worker_program = worker.provider_program
        worker_model = worker.model_hint

    binding_project_key = str(existing_binding.get("project_key") or "").strip() if isinstance(existing_binding, dict) else ""
    binding_agent_name = str(existing_binding.get("agent_name") or "").strip() if isinstance(existing_binding, dict) else ""
    binding_program = str(existing_binding.get("program") or "").strip() if isinstance(existing_binding, dict) else ""

    project_key = (
        str(explicit_project_key or "").strip()
        or registry_project_key
        or pane.bound_project_key
        or binding_project_key
    )
    agent_name = (
        str(explicit_agent_name or "").strip()
        or registry_agent_name_value
        or pane.bound_agent_name
        or binding_agent_name
    )
    program = (
        str(explicit_program or "").strip()
        or worker_program
        or pane.bound_program
        or binding_program
    )

    return {
        "project_key": project_key,
        "agent_name": agent_name,
        "program": program,
        "pane_key": pane.composite_key,
        "pane_id": pane.pane_id,
        "session_name": pane.session_name,
        "pane_title": pane.title,
        "pane_current_path": pane.current_path,
        "pane_current_command": pane.current_command,
        "registry_project_key": registry_project_key,
        "registry_agent_name": registry_agent_name_value,
        "registry_session_name": registry_session_name,
        "worker_program": worker_program,
        "worker_model": worker_model,
        "bound_project_key": pane.bound_project_key,
        "bound_agent_name": pane.bound_agent_name,
        "bound_program": pane.bound_program,
        "binding_project_key": binding_project_key,
        "binding_agent_name": binding_agent_name,
        "binding_program": binding_program,
    }


def command_current_assignment(config: Config, args: argparse.Namespace) -> int:
    pane = cli_target_pane(args, command_name="current-assignment")
    assignment = resolve_assignment_for_pane(
        config,
        pane,
        explicit_project_key=getattr(args, "project", None),
        explicit_agent_name=getattr(args, "agent", None),
        explicit_program=getattr(args, "program", None),
    )
    if args.field:
        value = assignment.get(args.field)
        if value is None:
            raise SystemExit(f"field {args.field!r} is not available")
        print(value)
        return 0
    print(json.dumps(assignment, indent=2, sort_keys=True))
    return 0


def command_provision_current_pane(config: Config, args: argparse.Namespace) -> int:
    pane = cli_target_pane(args, command_name="provision-current-pane")
    assignment = resolve_assignment_for_pane(
        config,
        pane,
        explicit_project_key=getattr(args, "project", None),
        explicit_agent_name=getattr(args, "agent", None),
        explicit_program=getattr(args, "program", None),
    )
    project_key = str(assignment.get("project_key") or "").strip()
    agent_name = str(assignment.get("agent_name") or "").strip()
    program = str(assignment.get("program") or "").strip() or None
    if not project_key:
        raise SystemExit("could not determine project_key for the current pane; pass --project explicitly")
    if not agent_name:
        raise SystemExit("could not determine agent_name for the current pane; pass --agent explicitly")

    bindings = scrub_unsafe_binding_session_ids(config).get("bindings", {})
    existing = bindings.get(binding_key(project_key, agent_name))
    session_id = str(getattr(args, "session_id", "") or "").strip() or None
