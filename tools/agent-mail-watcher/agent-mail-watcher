        return
    for name in TMUX_TRANSIENT_ENV_VARS:
        try:
            run_command(["tmux", "set-environment", "-gru", name], check=True)
        except subprocess.CalledProcessError:
            continue


def read_process_environ(pid: int) -> dict[str, str]:
    if pid <= 0:
        return {}
    try:
        raw = pathlib.Path(f"/proc/{pid}/environ").read_bytes()
    except OSError:
        return {}
    values: dict[str, str] = {}
    for item in raw.split(b"\0"):
        if not item or b"=" not in item:
            continue
        key, value = item.split(b"=", 1)
        try:
            values[key.decode("utf-8", errors="ignore")] = value.decode("utf-8", errors="ignore")
        except Exception:
            continue
    return values


def process_tree_pids(root_pid: int, *, max_nodes: int = 12) -> list[int]:
    if root_pid <= 0:
        return []
    queue = [root_pid]
    ordered: list[int] = []
    seen: set[int] = set()
    while queue and len(seen) < max_nodes:
        pid = queue.pop(0)
        if pid in seen:
            continue
        seen.add(pid)
        ordered.append(pid)
        children_path = pathlib.Path(f"/proc/{pid}/task/{pid}/children")
        try:
            raw_children = children_path.read_text(encoding="utf-8").strip()
        except OSError:
            continue
        for token in raw_children.split():
            if token.isdigit():
                queue.append(int(token))
    return ordered


def read_process_cmdline(pid: int) -> list[str]:
    if pid <= 0:
        return []
    try:
        raw = pathlib.Path(f"/proc/{pid}/cmdline").read_bytes()
    except OSError:
        return []
    return [part.decode("utf-8", errors="ignore") for part in raw.split(b"\0") if part]


def pane_launcher_argv(
    pane: PaneInfo,
    *,
    tree_cache: dict[int, list[int]] | None = None,
) -> list[str]:
    if pane.pid <= 0:
        return []
    if tree_cache is not None and pane.pid in tree_cache:
        pids = tree_cache[pane.pid]
    else:
        pids = process_tree_pids(pane.pid, max_nodes=4)
        if tree_cache is not None:
            tree_cache[pane.pid] = pids
    if len(pids) < 2:
        return []
    return read_process_cmdline(pids[1])


def process_tree_env_value(
    root_pid: int,
    key: str,
    *,
    env_cache: dict[int, dict[str, str]] | None = None,
    tree_cache: dict[int, list[int]] | None = None,
) -> str:
    if root_pid <= 0 or not key:
        return ""
    if tree_cache is not None and root_pid in tree_cache:
        pids = tree_cache[root_pid]
    else:
        pids = process_tree_pids(root_pid)
        if tree_cache is not None:
            tree_cache[root_pid] = pids
    for pid in pids:
        if env_cache is not None and pid in env_cache:
            environ = env_cache[pid]
        else:
            environ = read_process_environ(pid)
            if env_cache is not None:
                env_cache[pid] = environ
        candidate = str(environ.get(key) or "").strip()
        if candidate:
            return candidate
    return ""


def normalize_whitespace(value: str) -> str:
    return " ".join(value.split()).strip().lower()


def ensure_parent(path: pathlib.Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)


def read_json(path: pathlib.Path, default: Any) -> Any:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return default
    except json.JSONDecodeError:
        return default


def write_json_atomic(path: pathlib.Path, payload: Any) -> None:
    ensure_parent(path)
    temp_path = path.with_suffix(f"{path.suffix}.tmp")
    temp_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    temp_path.replace(path)


def parse_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def append_jsonl(path: pathlib.Path, payload: dict[str, Any], *, max_lines: int | None = None) -> None:
    ensure_parent(path)
    serialized = json.dumps(payload, sort_keys=True)
    if max_lines is None or max_lines <= 0:
        with path.open("a", encoding="utf-8") as handle:
            handle.write(serialized)
            handle.write("\n")
        return

    retained_lines: deque[str] = deque(maxlen=max_lines)
    if path.exists():
        with path.open("r", encoding="utf-8", errors="replace") as handle:
            for raw_line in handle:
                retained_lines.append(raw_line.rstrip("\n"))
    retained_lines.append(serialized)

    temp_path = path.with_suffix(f"{path.suffix}.tmp")
    with temp_path.open("w", encoding="utf-8") as handle:
        for line in retained_lines:
            handle.write(line)
            handle.write("\n")
    temp_path.replace(path)


def run_command(
    args: list[str],
    *,
    check: bool = True,
    capture_output: bool = True,
    text: bool = True,
    cwd: str | pathlib.Path | None = None,
    timeout: float | None = None,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        check=check,
        capture_output=capture_output,
        text=text,
        cwd=cwd,
        timeout=timeout,
    )


def tmux_available() -> bool:
    return subprocess.run(["tmux", "list-panes", "-a"], capture_output=True, text=True).returncode == 0


