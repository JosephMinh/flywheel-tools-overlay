def default_config_payload() -> dict[str, Any]:
    config = Config.load(DEFAULT_CONFIG_PATH)
    return config.to_json()


def command_init_config(path: pathlib.Path) -> int:
    if path.exists():
        print(f"config already exists at {path}", file=sys.stderr)
        return 1
    write_json_atomic(path, default_config_payload())
    print(path)
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--config",
        default=str(DEFAULT_CONFIG_PATH),
        help=f"Path to watcher config (default: {DEFAULT_CONFIG_PATH})",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    watch_parser = subparsers.add_parser("watch", help="Continuously watch Agent Mail signals")
    watch_parser.set_defaults(handler=lambda config, args: command_watch(config))

    once_parser = subparsers.add_parser("scan-once", help="Process any pending signals once")
    once_parser.set_defaults(handler=lambda config, args: print(json.dumps(scan_once(config), indent=2, sort_keys=True)) or 0)

    bind_parser = subparsers.add_parser("bind", help="Bind an agent to a preferred tmux pane")
    bind_parser.add_argument("--project", required=True, help="Canonical project path")
    bind_parser.add_argument("--agent", required=True, help="Agent name")
    bind_parser.add_argument("--pane", help="Pane id or composite pane key; defaults to current TMUX_PANE")
    bind_parser.add_argument("--program", help="Agent program/provider (e.g. codex-cli)")
    bind_parser.add_argument("--session-id", help="Optional provider session id for precise resume fallback")
    bind_parser.set_defaults(handler=command_bind)

    assignment_parser = subparsers.add_parser(
        "current-assignment",
        help="Show the watcher-resolved ownership assignment for the current tmux pane",
    )
    assignment_parser.add_argument("--pane", help="Pane id or composite pane key; defaults to current TMUX_PANE")
    assignment_parser.add_argument("--project", help="Override the resolved project path")
    assignment_parser.add_argument("--agent", help="Override the resolved agent name")
    assignment_parser.add_argument("--program", help="Override the resolved provider program")
    assignment_parser.add_argument(
        "--field",
        choices=("project_key", "agent_name", "program", "pane_key", "pane_id"),
        help="Print only a single resolved field",
    )
    assignment_parser.set_defaults(handler=command_current_assignment)

    provision_parser = subparsers.add_parser(
        "provision-current-pane",
        help="Provision watcher ownership metadata for the current tmux pane without calling Agent Mail",
    )
    provision_parser.add_argument("--pane", help="Pane id or composite pane key; defaults to current TMUX_PANE")
    provision_parser.add_argument("--project", help="Override the resolved project path")
    provision_parser.add_argument("--agent", help="Override the resolved agent name")
    provision_parser.add_argument("--program", help="Override the resolved provider program")
    provision_parser.add_argument("--session-id", help="Optional provider session id to persist on the binding")
    provision_parser.set_defaults(handler=command_provision_current_pane)

    status_parser = subparsers.add_parser("status", help="Show watcher status")
    status_parser.set_defaults(handler=lambda config, args: command_status(config))

    self_test_parser = subparsers.add_parser("self-test", help="Run an end-to-end detached tmux self-test")
    self_test_parser.set_defaults(handler=lambda config, args: command_self_test(config))

    init_config_parser = subparsers.add_parser("init-config", help="Write a default config if absent")
    init_config_parser.set_defaults(
        handler=lambda config, args: command_init_config(config.config_path)
    )

    args = parser.parse_args()
    config_path = pathlib.Path(args.config).expanduser()
    config = Config.load(config_path)
    return int(args.handler(config, args) or 0)


if __name__ == "__main__":
    raise SystemExit(main())
