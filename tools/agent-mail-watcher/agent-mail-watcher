    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def wait_for_pane_text(pane_id: str, needle: str, *, timeout_seconds: float = 3.0) -> str:
    deadline = time.monotonic() + timeout_seconds
    last_capture = ""
    while time.monotonic() < deadline:
        last_capture = run_command(["tmux", "capture-pane", "-p", "-t", pane_id]).stdout
        if needle in last_capture:
            return last_capture
        time.sleep(0.1)
    return last_capture


def setup_self_test_project(
    *,
    mailbox_root: pathlib.Path,
    project_slug: str,
    project_key: str,
    agent_name: str,
    program: str,
) -> None:
    project_dir = mailbox_root / "projects" / project_slug
