            bindings,
            project_key=project_key,
            agent_name=agent_name,
            session_id=existing.get("session_id"),
        )

    save_binding(
        config,
        project_key=project_key,
        agent_name=agent_name,
        pane=pane,
        program=program,
        session_id=session_id,
    )
    assignment["project_key"] = project_key
    assignment["agent_name"] = agent_name
    assignment["program"] = program
    assignment["session_id"] = session_id
    assignment["identity_path"] = str(canonical_identity_path(project_key, pane.composite_key))
    assignment["pane_id_identity_path"] = str(canonical_identity_path(project_key, pane.pane_id))
    print(json.dumps(assignment, indent=2, sort_keys=True))
    return 0


